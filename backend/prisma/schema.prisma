// backend/prisma/models/inventory/entryNote.prisma

enum EntryNoteStatus {
  PENDING       // Pendiente de verificación
  IN_PROGRESS   // En proceso de recepción
  COMPLETED     // Completada
  CANCELLED     // Cancelada
}

enum EntryType {
  PURCHASE        // Entrada por compra (vinculada a PurchaseOrder)
  RETURN          // Devolución de cliente
  TRANSFER        // Traslado desde otro almacén
  WARRANTY_RETURN // Devolución por garantía
  LOAN_RETURN     // Devolución de préstamo
  ADJUSTMENT_IN   // Ajuste de entrada
  DONATION        // Donación recibida
  SAMPLE          // Muestra recibida
  OTHER           // Otro
}

model EntryNote {
  id               String          @id @default(uuid())
  entryNoteNumber  String          @unique
  type             EntryType       @default(PURCHASE)
  status           EntryNoteStatus @default(PENDING)
  
  // Relación OPCIONAL con Orden de Compra
  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  
  warehouseId      String
  warehouse        Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  // Relación formal con Catálogo de Proveedores
  catalogSupplierId String?
  catalogSupplier   Supplier?      @relation(fields: [catalogSupplierId], references: [id], onDelete: SetNull)

  // Snapshots históricos para entradas sin orden de compra o auditoría
  supplierName     String?
  supplierId       String?         // Cédula/RIF del proveedor o texto libre
  supplierPhone    String?
  
  reason           String?         @db.Text
  reference        String?         // Número de guía, ticket, etc.
  
  // Relaciones
  items            EntryNoteItem[]
  
  // Relación con Transfer (cuando type=TRANSFER)
  transfer         Transfer?

  notes            String?         @db.Text
  
  // Fechas
  receivedAt       DateTime?
  verifiedAt       DateTime?
  
  // Auditoría
  receivedBy       String?
  verifiedBy       String?
  authorizedBy     String?         // Quien autorizó entrada sin OC
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("entry_notes")
  @@index([entryNoteNumber])
  @@index([type])
  @@index([status])
  @@index([purchaseOrderId])
  @@index([warehouseId])
}


// backend/prisma/models/inventory/entryNoteItem.prisma

model EntryNoteItem {
  id               String        @id @default(uuid())
  
  entryNoteId      String
  entryNote        EntryNote     @relation(fields: [entryNoteId], references: [id], onDelete: Cascade)
  
  itemId           String
  item             Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  // Snapshot histórico del nombre del artículo (editable)
  itemName         String?

  quantityReceived Int
  
  unitCost         Decimal       @db.Decimal(12, 2)
  
  // Ubicación destino en almacén
  storedToLocation String?
  
  // Trazabilidad
  batchId          String?
  batch            Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)
  
  serialNumberId   String?
  serialNumber     SerialNumber? @relation(fields: [serialNumberId], references: [id], onDelete: SetNull)
  
  // Fallback para lotes sin registro formal
  batchNumber      String?
  expiryDate       DateTime?
  
  notes            String?       @db.Text
  
  createdAt        DateTime      @default(now())

  @@map("entry_note_items")
  @@index([entryNoteId])
  @@index([itemId])
}


/**
 * Event Model - Audit trail for all inventory events
 */

enum EventTypeEnum {
  // Stock Events
  STOCK_CREATED
  STOCK_UPDATED
  STOCK_RESERVED
  STOCK_UNRESERVED
  STOCK_MOVEMENT_CREATED
  STOCK_LOW
  
  // Adjustment Events
  ADJUSTMENT_CREATED
  ADJUSTMENT_APPROVED
  ADJUSTMENT_APPLIED
  ADJUSTMENT_REJECTED
  ADJUSTMENT_CANCELLED
  
  // Cycle Count Events
  CYCLE_COUNT_CREATED
  CYCLE_COUNT_APPROVED
  CYCLE_COUNT_APPLIED
  CYCLE_COUNT_REJECTED
  CYCLE_COUNT_COMPLETED
  
  // Reconciliation Events
  RECONCILIATION_CREATED
  RECONCILIATION_APPROVED
  RECONCILIATION_APPLIED
  RECONCILIATION_REJECTED
  
  // Loan Events
  LOAN_CREATED
  LOAN_APPROVED
  LOAN_ACTIVE
  LOAN_RETURNED
  LOAN_OVERDUE
  
  // External Repair Events
  EXTERNAL_REPAIR_CREATED
  EXTERNAL_REPAIR_SENT
  EXTERNAL_REPAIR_RECEIVED
  EXTERNAL_REPAIR_QUALITY_CHECK
  EXTERNAL_REPAIR_REJECTED
  
  // Return Events
  RETURN_CREATED
  RETURN_APPROVED
  RETURN_PROCESSED
  RETURN_REJECTED
  
  // Transfer Events
  TRANSFER_CREATED
  TRANSFER_SENT
  TRANSFER_RECEIVED
  
  // Serial Number Events
  SERIAL_CREATED
  SERIAL_ASSIGNED_LOCATION
  SERIAL_STATUS_CHANGED
  
  // Item Events
  ITEM_CREATED
  ITEM_UPDATED
  ITEM_DELETED
  
  // Batch Events
  BATCH_CREATED
  BATCH_EXPIRING_SOON
  BATCH_EXPIRED
  
  // System Events
  SYSTEM_ALERT
  SYSTEM_WARNING
  SYSTEM_ERROR
}

enum EventPriorityEnum {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Event {
  id           String @id @default(uuid())
  type         EventTypeEnum
  entityId     String @db.VarChar(36)
  entityType   String @db.VarChar(50)
  userId       String @db.VarChar(36)
  eventData    Json @db.JsonB
  priority     EventPriorityEnum @default(MEDIUM)
  
  createdAt    DateTime @default(now())
  
  // Indices for queries
  @@index([entityId])
  @@index([entityType])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}


// backend/prisma/models/inventory/exitNote.prisma

enum ExitNoteStatus {
  PENDING      // Pendiente de preparación
  IN_PROGRESS  // En preparación
  READY        // Listo para entrega
  DELIVERED    // Entregado
  CANCELLED    // Cancelado
}

enum ExitType {
  SALE            // Venta normal (vinculada a Pre-factura)
  WARRANTY        // Garantía
  LOAN            // Préstamo
  INTERNAL_USE    // Consumo interno
  SAMPLE          // Muestra
  DONATION        // Donación
  OWNER_PICKUP    // Retiro del dueño
  DEMO            // Demostración
  TRANSFER        // Traslado
  OTHER           // Otro
  LOAN_RETURN     // Devolución de préstamo
}

model ExitNote {
  id              String         @id @default(uuid())
  exitNoteNumber  String         @unique
  type            ExitType       @default(SALE)
  status          ExitNoteStatus @default(PENDING)
  
  // Relación OPCIONAL con Pre-factura
  preInvoiceId    String?        @unique
  preInvoice      PreInvoice?    @relation(fields: [preInvoiceId], references: [id], onDelete: Restrict)
  
  warehouseId     String
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  // Para salidas sin factura
  recipientName   String?
  recipientId     String?        // Cédula/RIF
  recipientPhone  String?
  
  reason          String?        @db.Text
  reference       String?        // Número de orden externa, ticket, etc.
  
  // Para préstamos
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  
  // Relaciones
  items           ExitNoteItem[]
  reservations    Reservation[]
  loanId          String? @unique
  loan            Loan? @relation(fields: [loanId], references: [id], onDelete: Restrict)
  
  // Relación con Transfer (cuando type=TRANSFER)
  transfer        Transfer?

  notes           String?        @db.Text
  
  // Fechas
  reservedAt      DateTime?
  preparedAt      DateTime?
  deliveredAt     DateTime?
  
  // Auditoría
  preparedBy      String?
  deliveredBy     String?
  authorizedBy    String?        // Quien autorizó salida sin factura
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("exit_notes")
  @@index([exitNoteNumber])
  @@index([type])
  @@index([status])
  @@index([preInvoiceId])
}

// backend/prisma/models/inventory/exitNoteItem.prisma

model ExitNoteItem {
  id              String     @id @default(uuid())
  
  exitNoteId      String
  exitNote        ExitNote   @relation(fields: [exitNoteId], references: [id], onDelete: Cascade)
  
  itemId          String
  item            Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  quantity        Int
  itemName         String?          @db.VarChar(255)  // ← NUEVO: snapshot del nombre
  // ... resto ...
  // Ubicación física de donde se tomó
  pickedFromLocation String?
  
  // Trazabilidad
  batchId         String?
  batch           Batch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  
  serialNumberId  String?
  serialNumber    SerialNumber? @relation(fields: [serialNumberId], references: [id], onDelete: SetNull)
  
  notes           String?    @db.Text
  
  createdAt       DateTime   @default(now())

  @@map("exit_note_items")
  @@index([exitNoteId])
  @@index([itemId])
}

// backend/prisma/models/inventory/item.prisma

model Item {
  id          String   @id @default(uuid())
  sku         String
  code        String
  barcode     String?
  identity    String?
  name        String
  description String?  @db.Text

  // Multi-tenancy
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  // Relaciones de catálogo
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  modelId     String?
  model       Model?   @relation(fields: [modelId], references: [id], onDelete: SetNull)

  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  // Ubicación física en almacén
  location    String?  // "M1-R01-D03"

  // Precios
  costPrice      Decimal  @default(0) @db.Decimal(12, 2)
  salePrice      Decimal  @default(0) @db.Decimal(12, 2)
  wholesalePrice Decimal? @db.Decimal(12, 2)

  // Control de inventario
  minStock       Int      @default(5)
  maxStock       Int?     @default(100)
  reorderPoint   Int      @default(10)

  // Configuración de control
  isActive           Boolean  @default(true)
  isSerialized       Boolean  @default(false)  // Maneja números de serie
  hasBatch           Boolean  @default(false)  // Maneja lotes
  hasExpiry          Boolean  @default(false)  // Tiene fecha de vencimiento
  allowNegativeStock Boolean  @default(false)

  // Información básica extendida
  shortName             String?  @db.VarChar(20)  // nombrecorto
  reference             String?  @db.VarChar(20)  // referencia (texto libre, ≠ barcode)
  contraindications     String?  @db.Text         // contraindi

  // Flags del formulario de creación
  useStock              Boolean  @default(true)   // usaexist
  isFractionable        Boolean  @default(false)  // decimales ("fraccionable")
  isComposite           Boolean  @default(false)  // compuesto ("integrado")
  isInternalUse         Boolean  @default(false)  // usointerno
  useServer             Boolean  @default(false)  // usa_servidor
  suspendedForPurchase  Boolean  @default(false)  // discontc ("suspendido para la compra")

  // Configuración física/comercial
  warrantyDays          Int      @default(0)      // garantia
  packagingQty          Int      @default(1)      // empaque

  // Información adicional (flexible)
  technicalSpecs Json?    // Especificaciones técnicas
  tags           String[] // Tags para búsqueda: ["aceite", "sintético", "10w40"]

  // Relaciones
  stocks              Stock[]
  movements           Movement[]
  reservations        Reservation[]
  adjustmentItems     AdjustmentItem[]  @relation("AdjustmentItems")
  cycleCountItems     CycleCountItem[]  @relation("CycleCountItems")
  reconciliationItems ReconciliationItem[] @relation("ReconciliationItems")
  purchaseOrderItems PurchaseOrderItem[]
  orderItems     OrderItem[]
  preInvoiceItems PreInvoiceItem[]
  exitNoteItems  ExitNoteItem[]
  entryNoteItems EntryNoteItem[]
  invoiceItems   InvoiceItem[]
  batches        Batch[]
  serialNumbers  SerialNumber[]
  images         ItemImage[]
  pricing        Pricing?
  loanItems      LoanItem[]
  returnOrderItems ReturnOrderItem[]
  transferItems    TransferItem[]
  stockAlerts         StockAlert[]
  // Workshop: repuestos consumidos en OT
  serviceOrderItems   ServiceOrderItem[]
  // Workshop: materiales solicitados/despachados en OT
  serviceOrderMaterials ServiceOrderMaterial[]
  // Workshop: repuestos sugeridos en diagnósticos
  diagnosisSuggestedParts DiagnosisSuggestedPart[]
  // Auditoría con historial de cambios
  historial      Json?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("items")

  // Únicos por empresa
  @@unique([empresaId, sku], map: "items_empresa_sku_unique")
  @@unique([empresaId, code], map: "items_empresa_code_unique")
  @@unique([empresaId, barcode], map: "items_empresa_barcode_unique")

  @@index([sku])
  @@index([code])
  @@index([barcode])
  @@index([identity])
  @@index([brandId])
  @@index([categoryId])
  @@index([modelId])
  @@index([isActive])
  @@index([tags])
  @@index([empresaId])
}

// backend/prisma/models/inventory/itemImage.prisma

model ItemImage {
  id        String   @id @default(uuid())
  
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  url       String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  
  createdAt DateTime @default(now())

  @@map("item_images")
  @@index([itemId])
}

/**
 * Loan Model - Temporary loans of items with due date
 */

enum LoanStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  RETURNED
  OVERDUE
  CANCELLED
}

model Loan {
  id                  String @id @default(uuid())
  loanNumber          String @unique @db.VarChar(50)
  borrowerName        String @db.VarChar(255)
  borrowerId          String? @db.VarChar(36)
  status              LoanStatus @default(DRAFT)
  
  // Relationships
  warehouseId         String
  warehouse           Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  items               LoanItem[]
  exitNote            ExitNote?
  
  // Dates
  startDate           DateTime @default(now())
  dueDate             DateTime
  returnedAt          DateTime?
  approvedAt          DateTime?
  approvedBy          String? @db.VarChar(36)
  
  // Metadata
  purpose             String? @db.VarChar(255)
  notes               String? @db.Text
  createdBy           String @db.VarChar(36)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // Indices
  @@index([loanNumber])
  @@index([status])
  @@index([borrowerId])
  @@index([warehouseId])
  @@index([dueDate])
  @@index([createdAt])
  @@map("loans")
}

model LoanItem {
  id                  String @id @default(uuid())
  loanId              String
  loan                Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  
  itemId              String
  item                Item @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  quantityLoaned      Int
  quantityReturned    Int @default(0)
  unitCost            Decimal @default(0)
  
  notes               String? @db.Text
  createdAt           DateTime @default(now())
  
  @@unique([loanId, itemId])
  @@index([loanId])
  @@index([itemId])
  @@map("loan_items")
}

// backend/prisma/models/inventory/model.prisma

enum ModelType {
  VEHICLE       // Modelo de vehículo (Hilux 2020)
  PART          // Modelo de producto (PH3614, Lysol 500ml)
  GENERIC       // Genérico
}

model Model {
  id          String    @id @default(uuid())
  
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  brandId     String
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Restrict)
  
  code        String?   // Código del modelo
  name        String    // Nombre del modelo
  year        Int?      // Año (principalmente para vehículos)
  
  type        ModelType @default(PART)
  description String?
  
  // Especificaciones técnicas (JSON flexible)
  specifications Json?   // Ej: { "viscosity": "10W-40", "capacity": "500ml" }
  
  isActive    Boolean   @default(true)
  
  // Compatibilidad (para productos que aplique)
