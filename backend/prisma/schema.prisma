// backend/prisma/models/workshop/workshopRework.prisma
// Retrabajo: intervención realizada para corregir un trabajo defectuoso previo.
// Separado de WorkshopWarranty para permitir trazabilidad y costo propio.

enum ReworkStatus {
  OPEN        // Detectado / registrado
  IN_PROGRESS // Se abrió OT de retrabajo
  RESOLVED    // Trabajo corregido
  CLOSED      // Cerrado con análisis completo
}

model WorkshopRework {
  id          String @id @default(cuid())

  // OT original con el defecto
  originalOrderId String
  originalOrder   ServiceOrder @relation("ReworkOriginalOrder", fields: [originalOrderId], references: [id], onDelete: Restrict)

  // OT de corrección generada (puede generarse después)
  reworkOrderId String?
  reworkOrder   ServiceOrder? @relation("ReworkCorrectionOrder", fields: [reworkOrderId], references: [id], onDelete: SetNull)

  // Análisis
  motive      String          @db.Text // Motivo del retrabajo
  rootCause   String?         @db.Text // Causa raíz identificada
  technicianId String?                 // userId del técnico responsable del defecto

  // Costos
  estimatedCost Decimal @default(0) @db.Decimal(12, 2)
  realCost      Decimal @default(0) @db.Decimal(12, 2)

  status      ReworkStatus @default(OPEN)
  resolvedAt  DateTime?
  notes       String?      @db.Text

  empresaId   String
  empresa     Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([empresaId])
  @@index([originalOrderId])
  @@index([technicianId])
  @@index([status])
  @@map("workshop_reworks")
}


// backend/prisma/models/workshop/workshopShift.prisma
// Turnos de trabajo configurables del taller.
// Define las jornadas laborales para validación de asignaciones y disponibilidad.

model WorkshopShift {
  id        String @id @default(cuid())
  code      String
  name      String  // Ej: "Turno Mañana", "Turno Tarde"
  startTime String  // HH:MM en formato 24h, ej: "08:00"
  endTime   String  // HH:MM en formato 24h, ej: "17:00"

  // Días activos: array JSON de números 0=Dom, 1=Lun ... 6=Sáb
  // Ej: [1,2,3,4,5] = Lunes a Viernes
  workDays  Json    @default("[1,2,3,4,5]")

  isActive  Boolean @default(true)

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, code])
  @@index([empresaId])
  @@index([isActive])
  @@map("workshop_shifts")
}


// backend/prisma/models/workshop/workshopWarranty.prisma
// Gestión de garantías y retrabajos del taller.
// Una garantía siempre referencia la OT original.
// Cuando se aprueba, genera una nueva OT de retrabajo (a costo interno).

enum WarrantyType {
  LABOR       // Garantía de mano de obra
  PARTS       // Garantía de repuesto
  MIXED       // Ambas (mano de obra + repuesto)
  COMMERCIAL  // Garantía comercial (decisión gerencial)
  FACTORY     // Garantía de fábrica / fabricante
  SUPPLIER    // Garantía de proveedor
  CAMPAIGN    // Garantía de campaña / recall
}

enum WarrantyResponsibleCost {
  COMPANY     // La empresa absorbe el costo
  SUPPLIER    // El proveedor cubre el costo
  MANUFACTURER // El fabricante cubre el costo
  INSURER     // Aseguradora
  CLIENT      // El cliente paga (no aplica garantía)
}

enum WarrantyStatus {
  OPEN        // Abierta / en evaluación
  IN_PROGRESS // Se abrió OT de retrabajo
  RESOLVED    // Resuelto
  REJECTED    // Rechazada (no aplica garantía)
  CLOSED      // Cerrada
}

model WorkshopWarranty {
  id              String @id @default(cuid())
  warrantyNumber  String // WRN-0001 auto-generado por empresa

  type   WarrantyType
  status WarrantyStatus @default(OPEN)

  // OT de origen (trabajo que se está reclamando)
  originalOrderId String
  originalOrder   ServiceOrder @relation("OriginalOrder", fields: [originalOrderId], references: [id], onDelete: Restrict)

  // OT de retrabajo generada (cuando se aprueba la garantía)
  reworkOrderId String?
  reworkOrder   ServiceOrder? @relation("ReworkOrder", fields: [reworkOrderId], references: [id], onDelete: SetNull)

  // Cliente y vehículo
  customerId        String
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerVehicleId String?
  customerVehicle   CustomerVehicle? @relation(fields: [customerVehicleId], references: [id], onDelete: SetNull)

  // Descripción del reclamo
  description String @db.Text

  // Análisis y resolución
  rootCause   String? @db.Text
  resolution  String? @db.Text

  // Responsable del costo
  responsibleForCost WarrantyResponsibleCost @default(COMPANY)

  // Responsable técnico
  technicianId String? // userId del técnico responsable

  // Vigencia
  expiresAt  DateTime?
  resolvedAt DateTime?

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, warrantyNumber])
  @@index([empresaId])
  @@index([originalOrderId])
  @@index([customerId])
  @@index([status])
  @@index([technicianId])
  @@map("workshop_warranties")
}
