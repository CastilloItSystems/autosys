  isSystem        Boolean           @default(false)

  memberships     Membership[]
  permissions     RolePermission[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([name, empresaId])
  @@index([empresaId])
  @@map("company_roles")
}

