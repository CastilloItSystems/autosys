  updatedAt    DateTime @updatedAt

  @@unique([empresaId, code])
  @@unique([empresaId, abbreviation])
  @@map("units")
  @@index([code])
  @@index([type])
  @@index([empresaId])
}

// backend/prisma/models/inventory/warehouse.prisma

enum WarehouseType {
  PRINCIPAL  // Almacén principal
  SUCURSAL   // Sucursal/Tienda
  TRANSITO   // Almacén de tránsito
}

model Warehouse {
