// backend/prisma/models/inventory/serialNumber.prisma

enum SerialStatus {
  IN_STOCK    // En stock
  SOLD        // Vendido
  DEFECTIVE   // Defectuoso
  WARRANTY    // En garantía
  LOANED      // Prestado
}

model SerialNumber {
  id            String       @id @default(uuid())
  serialNumber  String       @unique
  
  itemId        String
  item          Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  warehouseId   String?
  warehouse     Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  status        SerialStatus @default(IN_STOCK)
  
  soldAt        DateTime?
  workOrderId   String?
  
  notes         String?      @db.Text
  
  // Relaciones
  preInvoiceItems PreInvoiceItem[]
  exitNoteItems   ExitNoteItem[]
  entryNoteItems  EntryNoteItem[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("serial_numbers")
  @@index([serialNumber])
  @@index([itemId])
  @@index([status])
}

// backend/prisma/models/inventory/stock.prisma

model Stock {
  id                String    @id @default(uuid())
  
  itemId            String
  item              Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  warehouseId       String
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  
  // Cantidades
  quantityReal      Int       @default(0)      // Stock físico real
  quantityReserved  Int       @default(0)      // Stock reservado
  quantityConsumed  Int       @default(0)      // Stock consumido/entregado
  quantityAvailable Int       @default(0)      // Real - Reservado
  
  // Valorización
  averageCost       Decimal   @default(0) @db.Decimal(12, 2)
  
  lastMovementAt    DateTime?
  
  // Auditoría
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([itemId, warehouseId])
  @@map("stocks")
  @@index([itemId])
  @@index([warehouseId])
  @@index([quantityAvailable])
}

// backend/prisma/models/inventory/stockAlert.prisma

enum AlertType {
  LOW_STOCK      // Stock bajo
  OUT_OF_STOCK   // Sin stock
  EXPIRING_SOON  // Próximo a vencer
  EXPIRED        // Vencido
  OVERSTOCK      // Exceso de stock
}

model StockAlert {
  id          String    @id @default(uuid())
  
  itemId      String
  warehouseId String
  
  type        AlertType
  message     String
  severity    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  
  isRead      Boolean   @default(false)
  readBy      String?
  readAt      DateTime?
  
  createdAt   DateTime  @default(now())

  @@map("stock_alerts")
  @@index([itemId])
  @@index([warehouseId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// backend/prisma/models/inventory/supplier.prisma

model Supplier {
