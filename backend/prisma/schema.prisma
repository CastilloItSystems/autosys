// backend/prisma/models/inventory/return.prisma

enum ReturnStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PROCESSED
  REJECTED
  CANCELLED
}

enum ReturnType {
  SUPPLIER_RETURN
