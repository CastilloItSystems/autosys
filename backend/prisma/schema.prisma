  @@unique([empresaId, code])
  @@map("brands")
  @@index([code])
  @@index([name])
  @@index([type])
  @@index([isActive])
  @@index([empresaId])
}

// backend/prisma/models/inventory/bulkOperation.prisma

enum BulkOperationType {
  IMPORT
  EXPORT
  UPDATE
  DELETE
  STOCK_IMPORT      // Carga inicial / entrada masiva de stock
  STOCK_ADJUSTMENT  // Ajustes masivos de stock (entradas/salidas)
  STOCK_TRANSFER    // Transferencias masivas entre almacenes
  STOCK_EXPORT      // Exportar niveles de stock
}

enum BulkOperationStatus {
  PENDING
