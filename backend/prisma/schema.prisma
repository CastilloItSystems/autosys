  warehouseId String
  
  type        AlertType
  message     String
  severity    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  
  isRead      Boolean   @default(false)
  readBy      String?
  readAt      DateTime?
  
  createdAt   DateTime  @default(now())

  @@map("stock_alerts")
  @@index([itemId])
  @@index([warehouseId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// backend/prisma/models/inventory/supplier.prisma

model Supplier {
  id              String          @id @default(uuid())
  code            String          @unique
  name            String
  contactName     String?
  email           String?
  phone           String?
  address         String?
  taxId           String?         // RIF en Venezuela
  isActive        Boolean         @default(true)
  
  // Relaciones
  purchaseOrders  PurchaseOrder[]
  
  // Auditoría
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("suppliers")
  @@index([code])
  @@index([isActive])
}

// backend/prisma/models/inventory/unit.prisma

enum UnitType {
  COUNTABLE  // Unidades contables
  WEIGHT     // Peso
  VOLUME     // Volumen
  LENGTH     // Longitud
}

model Unit {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  abbreviation String   @unique
  type         UnitType
  isActive     Boolean  @default(true)
  
  // Relaciones
  items        Item[]
  
  // Auditoría
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("units")
  @@index([code])
  @@index([type])
}

// backend/prisma/models/inventory/warehouse.prisma

enum WarehouseType {
  PRINCIPAL  // Almacén principal
  SUCURSAL   // Sucursal/Tienda
  TRANSITO   // Almacén de tránsito
}

model Warehouse {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  type        WarehouseType @default(PRINCIPAL)
  address     String?
  isActive    Boolean       @default(true)
  
  // Relaciones
  stocks          Stock[]
  movementsFrom   Movement[]    @relation("WarehouseFrom")
  movementsTo     Movement[]    @relation("WarehouseTo")
  orders          Order[]
  preInvoices     PreInvoice[]
  exitNotes       ExitNote[]
  purchaseOrders  PurchaseOrder[]
  
  // Auditoría
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("warehouses")
  @@index([code])
  @@index([type])
  @@index([isActive])
}

// backend/prisma/models/sales/customer.prisma

enum CustomerType {
  INDIVIDUAL  // Persona natural
  COMPANY     // Empresa
}

model Customer {
  id          String       @id @default(uuid())
  code        String       @unique
  taxId       String?      @unique // RIF/Cédula
  name        String
  email       String?
  phone       String?
  address     String?      @db.Text
  type        CustomerType @default(INDIVIDUAL)
  
  isActive    Boolean      @default(true)
  
  // Relaciones
  orders      Order[]
  preInvoices PreInvoice[]
  payments    Payment[]
  invoices    Invoice[]
  
  // Auditoría
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("customers")
  @@index([code])
  @@index([taxId])
  @@index([isActive])
}

// backend/prisma/models/sales/invoice.prisma

enum InvoiceStatus {
  ACTIVE     // Activa
  CANCELLED  // Anulada
  CREDITED   // Con nota de crédito
}

model Invoice {
  id                 String        @id @default(uuid())
  invoiceNumber      String        @unique
  fiscalNumber       String?       @unique // Número de control fiscal
  status             InvoiceStatus @default(ACTIVE)
  
  // Relación 1 a 1 con Pre-factura
  preInvoiceId       String        @unique
  preInvoice         PreInvoice    @relation(fields: [preInvoiceId], references: [id], onDelete: Restrict)
  
  // Relación 1 a 1 con Pago
  paymentId          String        @unique
  payment            Payment       @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  
  customerId         String
  customer           Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  // Relaciones
  items              InvoiceItem[]
  
  // Totales
  subtotal           Decimal       @default(0) @db.Decimal(12, 2)
  discount           Decimal       @default(0) @db.Decimal(12, 2)
  tax                Decimal       @default(0) @db.Decimal(12, 2)
  total              Decimal       @default(0) @db.Decimal(12, 2)
  
  notes              String?       @db.Text
  
  // Fiscal
  invoiceDate        DateTime      @default(now())
  
  // Auditoría
  issuedBy           String?
  
  // Anulación
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?       @db.Text
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("invoices")
  @@index([invoiceNumber])
  @@index([fiscalNumber])
  @@index([customerId])
  @@index([status])
  @@index([invoiceDate])
}

// backend/prisma/models/sales/invoiceItem.prisma

model InvoiceItem {
  id        String   @id @default(uuid())
  
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  tax       Decimal  @default(0) @db.Decimal(12, 2)
  subtotal  Decimal  @db.Decimal(12, 2)
  
  // Trazabilidad
  batchId        String?
  serialNumberId String?
  
  createdAt DateTime @default(now())

  @@map("invoice_items")
  @@index([invoiceId])
  @@index([itemId])
}

// backend/prisma/models/sales/order.prisma

enum OrderStatus {
  DRAFT              // Borrador
  PENDING_APPROVAL   // Pendiente de aprobación
  APPROVED           // Aprobado
  CANCELLED          // Cancelado
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  status          OrderStatus @default(DRAFT)
  
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  warehouseId     String
  warehouse       Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  // Relaciones
  items           OrderItem[]
  
  // Totales
  subtotal        Decimal     @default(0) @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @default(0) @db.Decimal(12, 2)
  
  notes           String?     @db.Text
  
  // Fechas
  orderDate       DateTime    @default(now())
  approvedAt      DateTime?
  
  // Auditoría
  createdBy       String?
  approvedBy      String?
  
  // Relación 1 a 1 con Pre-factura
  preInvoice      PreInvoice?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([orderDate])
}

// backend/prisma/models/sales/orderItem.prisma

model OrderItem {
  id        String   @id @default(uuid())
  
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  subtotal  Decimal  @db.Decimal(12, 2)
  
  notes     String?  @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
  @@index([orderId])
  @@index([itemId])
}

// backend/prisma/models/sales/payment.prisma

enum PaymentMethod {
  CASH            // Efectivo
  TRANSFER        // Transferencia
  CARD            // Tarjeta
  MOBILE_PAYMENT  // Pago móvil
  CHECK           // Cheque
  CREDIT          // Crédito
  MIXED           // Mixto
}

enum PaymentStatus {
  PENDING    // Pendiente
  COMPLETED  // Completado
  CANCELLED  // Cancelado
  REFUNDED   // Reembolsado
}

model Payment {
  id                String        @id @default(uuid())
  paymentNumber     String        @unique
  status            PaymentStatus @default(PENDING)
  
  preInvoiceId      String
  
  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  // Detalles del pago
  method            PaymentMethod
  amount            Decimal       @db.Decimal(12, 2)
  
  // Para pagos mixtos
  details           Json?         // [{ method: "CASH", amount: 100 }, ...]
  
  reference         String?       // Número de referencia
  notes             String?       @db.Text
  
  // Auditoría
  processedBy       String?
  processedAt       DateTime      @default(now())
  
  // Relación 1 a 1 con Factura
  invoice           Invoice?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("payments")
  @@index([paymentNumber])
  @@index([customerId])
  @@index([status])
  @@index([processedAt])
}

// backend/prisma/models/sales/preInvoice.prisma

enum PreInvoiceStatus {
  PENDING_PREPARATION  // Pendiente de preparación
  IN_PREPARATION       // En preparación
  READY_FOR_PAYMENT    // Listo para pago
  PAID                 // Pagado
  CANCELLED            // Cancelado
}

model PreInvoice {
  id                  String            @id @default(uuid())
  preInvoiceNumber    String            @unique
  status              PreInvoiceStatus  @default(PENDING_PREPARATION)
  
  // Relación 1 a 1 con Order
  orderId             String            @unique
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  
  customerId          String
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  warehouseId         String
  warehouse           Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  // Relaciones
  items               PreInvoiceItem[]
  
  // Totales
  subtotal            Decimal           @default(0) @db.Decimal(12, 2)
  discount            Decimal           @default(0) @db.Decimal(12, 2)
  tax                 Decimal           @default(0) @db.Decimal(12, 2)
  total               Decimal           @default(0) @db.Decimal(12, 2)
  
  notes               String?           @db.Text
  
  // Control de flujo
  preparedAt          DateTime?
  paidAt              DateTime?
  
  preparedBy          String?
  
  // Relaciones 1 a 1
  exitNote            ExitNote?
  invoice             Invoice?
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("pre_invoices")
  @@index([preInvoiceNumber])
  @@index([customerId])
  @@index([status])
}

// backend/prisma/models/sales/preInvoiceItem.prisma

model PreInvoiceItem {
  id              String      @id @default(uuid())
  
  preInvoiceId    String
  preInvoice      PreInvoice  @relation(fields: [preInvoiceId], references: [id], onDelete: Cascade)
  
  itemId          String
  item            Item        @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  quantity        Int
  unitPrice       Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  subtotal        Decimal     @db.Decimal(12, 2)
  
  // Trazabilidad
  batchId         String?
  batch           Batch?      @relation(fields: [batchId], references: [id], onDelete: SetNull)
  
  serialNumberId  String?
  serialNumber    SerialNumber? @relation(fields: [serialNumberId], references: [id], onDelete: SetNull)
  
  notes           String?     @db.Text
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("pre_invoice_items")
  @@index([preInvoiceId])
  @@index([itemId])
}

model User {
  id           String    @id @default(cuid())
  img          String?
  nombre       String
  correo       String    @unique
  telefono     String?
  password     String
  rol          Role      @default(VIEWER)
  departamento String[]
  acceso       Access    @default(ninguno)
  empresas     Empresa[]
  estado       UserStatus @default(activo)
  eliminado    Boolean   @default(false)
  online       Boolean   @default(false)
  fcmTokens    String[]
  google       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    AuditLog[]
}

enum UserStatus {
  pendiente
  activo
  suspendido
}

enum Role {
  SUPER_ADMIN
  ADMIN
  GERENTE
  VENDEDOR
  ALMACENISTA
  MECANICO
  CAJERO
  CONTADOR
  ASESOR
  VIEWER
}

enum Access {
  limitado
  completo
  ninguno
}
