  // Relaciones
  receptions VehicleReception[]

  @@unique([empresaId, code])
  @@index([empresaId])
  @@index([isActive])
  @@map("workshop_ingress_motives")
}


// backend/prisma/models/workshop/laborTime.prisma
// Control de tiempos técnicos por operación y técnico.
// Permite medir productividad, eficiencia y horas facturables.
// Regla: un técnico no puede tener dos registros ACTIVE simultáneamente.

enum LaborTimeStatus {
  ACTIVE     // Reloj corriendo
  PAUSED     // Pausado (espera de repuesto, autorización, etc.)
  COMPLETED  // Terminado
  CANCELLED  // Anulado (error de registro)
}

model LaborTime {
  id             String @id @default(cuid())

  // OT e ítem de operación
  serviceOrderId String
  serviceOrder   ServiceOrder      @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  serviceOrderItemId String?
  serviceOrderItem   ServiceOrderItem? @relation(fields: [serviceOrderItemId], references: [id], onDelete: SetNull)

  // Operación estándar de referencia (para comparar vs tiempo estándar)
  operationId String?
  operation   WorkshopOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  // Técnico
  technicianId String // userId del técnico

  // Tiempos
  startedAt   DateTime  // Cuando inició
  pausedAt    DateTime? // Última pausa (null si activo)
  finishedAt  DateTime? // Cuando terminó

  // Acumulados calculados (en minutos)
  pausedMinutes   Int @default(0) // Total de minutos pausado
  realMinutes     Int? // Minutos reales (finishedAt - startedAt - pausedMinutes)
  standardMinutes Int? // Tiempo estándar de la operación al momento de registrar

  status LaborTimeStatus @default(ACTIVE)

  notes    String? @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pauses LaborTimePause[]

  @@index([serviceOrderId])
  @@index([serviceOrderItemId])
  @@index([technicianId])
  @@index([status])
  @@index([startedAt])
  @@index([technicianId, status]) // Buscar timer activo de un técnico
  @@map("workshop_labor_times")
}

model LaborTimePause {
  id             String    @id @default(cuid())
  laborTimeId    String
  laborTime      LaborTime @relation(fields: [laborTimeId], references: [id], onDelete: Cascade)

  startedAt      DateTime
  endedAt        DateTime?
  durationMinutes Int?     // Calculado al finalizar la pausa
  reason         String?   @db.Text

  empresaId      String
  empresa        Empresa   @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdAt      DateTime  @default(now())

  @@index([laborTimeId])
  @@index([empresaId])
  @@map("workshop_labor_time_pauses")
}



// backend/prisma/models/workshop/materialMovement.prisma
// Historial de movimientos de cada material en una OT.
// Registra quién hizo qué, cuándo y desde qué almacén.
// Cada cambio de estado en ServiceOrderMaterial debe generar un registro aquí.

enum MaterialMovementType {
  RESERVATION   // Cantidad reservada en inventario
  DISPATCH      // Despacho físico desde almacén a la OT
  CONSUMPTION   // Consumo registrado por el técnico
  RETURN        // Devolución al almacén
  ADJUSTMENT    // Ajuste de cantidad por error u otro motivo
  CANCELLATION  // Cancelación del material
}

model ServiceOrderMaterialMovement {
  id               String @id @default(cuid())
  materialId       String
  material         ServiceOrderMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  type             MaterialMovementType
  quantity         Decimal  @db.Decimal(12, 2)
  previousQuantity Decimal? @db.Decimal(12, 2) // Snapshot de la cantidad antes del movimiento

  // Trazabilidad de inventario
  warehouseId      String?  // Almacén origen/destino (referencia soft, no FK)
  warehouseName    String?  // Snapshot del nombre del almacén

  // Auditoría
  userId           String   // Quien ejecutó el movimiento
  notes            String?  @db.Text
  referenceId      String?  // ID de referencia externa (ej: movimiento de inventario)

  empresaId        String
  empresa          Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdAt        DateTime @default(now())

  @@index([materialId])
  @@index([empresaId])
  @@index([materialId, type]) // Movimientos de un tipo específico para un material
  @@map("workshop_material_movements")
}


// backend/prisma/models/workshop/qualityCheck.prisma
// Control de calidad pre-entrega del vehículo.
// Se ejecuta antes de mover la OT a READY.
// Si falla → se registra motivo y se regresa a IN_PROGRESS.

enum QualityCheckStatus {
  PENDING     // Por realizar
  IN_PROGRESS // En proceso de revisión
  PASSED      // Aprobado - vehículo listo para entregar
  FAILED      // Reprobado - requiere retrabajo
}

model QualityCheck {
  id             String       @id @default(cuid())

  serviceOrderId String       @unique // 1:1 con ServiceOrder
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  inspectorId String // userId del inspector (técnico jefe, asesor QC, etc.)

  status QualityCheckStatus @default(PENDING)

  // Checklist flexible (antiguo/hardcoded)
  checklistItems Json?

  // Checklist dinámico
  checklistTemplateId String?
  checklistTemplate   ChecklistTemplate?  @relation(fields: [checklistTemplateId], references: [id], onDelete: SetNull)
  checklistResponses  ChecklistResponse[]

  // Si falla
  failureNotes String? @db.Text
  retryCount   Int     @default(0) // Cuántas veces reprobó

  // Fechas
  startedAt  DateTime?
  completedAt DateTime?

  notes     String? @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceOrderId])
  @@index([inspectorId])
  @@index([status])
  @@map("workshop_quality_checks")
}


