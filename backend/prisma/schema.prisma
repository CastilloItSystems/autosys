  catalogSupplierId String?
  catalogSupplier   Supplier?      @relation(fields: [catalogSupplierId], references: [id], onDelete: SetNull)

  // Snapshots históricos para entradas sin orden de compra o auditoría
  supplierName     String?
  supplierId       String?         // Cédula/RIF del proveedor o texto libre
  supplierPhone    String?
  
  reason           String?         @db.Text
  reference        String?         // Número de guía, ticket, etc.
  
  // Relaciones
