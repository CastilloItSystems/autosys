// backend/prisma/models/sales/payment.prisma

enum PaymentMethod {
  CASH            // Efectivo
  TRANSFER        // Transferencia
  CARD            // Tarjeta
  MOBILE_PAYMENT  // Pago móvil
  CHECK           // Cheque
  CREDIT          // Crédito
  MIXED           // Mixto
}

enum PaymentStatus {
  PENDING    // Pendiente
  COMPLETED  // Completado
  CANCELLED  // Cancelado
  REFUNDED   // Reembolsado
}

model Payment {
  id                String        @id @default(uuid())
  paymentNumber     String        @unique
  status            PaymentStatus @default(PENDING)

  // ── Multi-tenancy ──
  empresaId         String
  empresa           Empresa       @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  // ── Relación con PreInvoice ──
  preInvoiceId      String
  preInvoice        PreInvoice    @relation(fields: [preInvoiceId], references: [id], onDelete: Restrict)

  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // ── Detalles del pago ──
  method            PaymentMethod
  amount            Decimal       @db.Decimal(12, 2)

  // ── Moneda ──
  currency          OrderCurrency @default(USD)
  exchangeRate      Decimal?      @db.Decimal(14, 4)

  // ── IGTF (si paga en divisas) ──
  igtfApplies       Boolean       @default(false)
  igtfAmount        Decimal       @default(0) @db.Decimal(12, 2)
  totalWithIgtf     Decimal       @default(0) @db.Decimal(12, 2)

  // ── Para pagos mixtos ──
  details           Json?         // [{ method: "CASH", amount: 100, reference: "..." }, ...]

  reference         String?       // Número de referencia
  notes             String?       @db.Text

  // ── Auditoría ──
  processedBy       String?
  processedAt       DateTime      @default(now())

  // ── Relación 1 a 1 con Factura ──
  invoice           Invoice?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("payments")
  @@index([paymentNumber])
  @@index([customerId])
  @@index([preInvoiceId])
  @@index([status])
  @@index([processedAt])
  @@index([empresaId])
}


// backend/prisma/models/sales/preInvoice.prisma

enum PreInvoiceStatus {
  PENDING_PREPARATION  // Pendiente de preparación
  IN_PREPARATION       // En preparación
  READY_FOR_PAYMENT    // Listo para pago
  PAID                 // Pagado
  CANCELLED            // Cancelado
}

model PreInvoice {
  id                  String            @id @default(uuid())
  preInvoiceNumber    String            @unique
  status              PreInvoiceStatus  @default(PENDING_PREPARATION)

  empresaId           String
  empresa             Empresa           @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  // Relación 1 a 1 con Order
  orderId             String            @unique
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)

  customerId          String
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)

  warehouseId         String
  warehouse           Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  // Relaciones
  items               PreInvoiceItem[]

  // ── Moneda y tasa ──
  currency            OrderCurrency     @default(USD)
  exchangeRate        Decimal?          @db.Decimal(14, 4)

  // ── Descuento general ──
  discountAmount      Decimal           @default(0) @db.Decimal(12, 2)

  // ── Totales fiscales ──
  subtotalBruto       Decimal           @default(0) @db.Decimal(12, 2)
  baseImponible       Decimal           @default(0) @db.Decimal(12, 2)
  baseExenta          Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal           @default(0) @db.Decimal(12, 2)
  taxRate             Decimal           @default(16) @db.Decimal(5, 2)

  // ── IGTF ──
  igtfApplies         Boolean           @default(false)
  igtfRate            Decimal           @default(3) @db.Decimal(5, 2)
  igtfAmount          Decimal           @default(0) @db.Decimal(12, 2)

  // ── Total final ──
  total               Decimal           @default(0) @db.Decimal(12, 2)

  // ── Campos legacy ──
  subtotal            Decimal           @default(0) @db.Decimal(12, 2)
  discount            Decimal           @default(0) @db.Decimal(12, 2)
  tax                 Decimal           @default(0) @db.Decimal(12, 2)

  notes               String?           @db.Text

  // Control de flujo
  preparedAt          DateTime?
  paidAt              DateTime?
  preparedBy          String?

  // Relaciones 1 a 1
  exitNote            ExitNote?
  invoice             Invoice?

  payments            Payment[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("pre_invoices")
  @@index([preInvoiceNumber])
  @@index([customerId])
  @@index([status])
  @@index([empresaId])
}


// backend/prisma/models/sales/preInvoiceItem.prisma

model PreInvoiceItem {
  id              String        @id @default(uuid())

  preInvoiceId    String
  preInvoice      PreInvoice    @relation(fields: [preInvoiceId], references: [id], onDelete: Cascade)

  itemId          String
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)

  // ── Snapshot ──
  itemName        String?       @db.VarChar(255)

  quantity        Int
  unitPrice       Decimal       @db.Decimal(12, 2)

  // ── Descuento por línea ──
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)

  // ── Impuesto por línea ──
  taxType         TaxType       @default(IVA)
  taxRate         Decimal       @default(16) @db.Decimal(5, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)

  // ── Subtotal y total línea ──
  subtotal        Decimal       @db.Decimal(12, 2)
  totalLine       Decimal       @default(0) @db.Decimal(12, 2)

