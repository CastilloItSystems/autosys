model Adjustment {
  id                String             @id @default(uuid())
  adjustmentNumber  String             @unique
  
  warehouseId       String
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  status            AdjustmentStatus   @default(DRAFT)
  reason            String             @db.VarChar(255)
  notes             String?            @db.Text
  
  // Aprobación
  approvedBy        String?
  approvedAt        DateTime?
  
  // Aplicación
  appliedBy         String?
  appliedAt         DateTime?
  
  // Relaciones
  items             AdjustmentItem[]
  
  // Auditoría
  createdBy         String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("adjustments")
  @@index([adjustmentNumber])
  @@index([warehouseId])
  @@index([status])
  @@index([createdAt])
}


// backend/prisma/models/inventory/adjustmentItem.prisma

model AdjustmentItem {
  id               String      @id @default(uuid())
  
  adjustmentId     String
  adjustment       Adjustment  @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  
  itemId           String
  item             Item        @relation("AdjustmentItems", fields: [itemId], references: [id], onDelete: Restrict)
  
  quantityChange   Int         // Puede ser positivo o negativo
  currentQuantity  Int?        // Cantidad antes del ajuste
  newQuantity      Int?        // Cantidad después del ajuste
  
  unitCost         Decimal?    @db.Decimal(12, 2)
  notes            String?     @db.Text
  
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([adjustmentId, itemId]) // No duplicar items en mismo ajuste
  @@map("adjustment_items")
  @@index([adjustmentId])
  @@index([itemId])
}


// backend/prisma/models/inventory/batch.prisma

model Batch {
  id                String     @id @default(uuid())
  batchNumber       String     @unique
  
  itemId            String
  item              Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  manufacturingDate DateTime?
  expiryDate        DateTime?
  
  initialQuantity   Int
  currentQuantity   Int
  
  isActive          Boolean    @default(true)
  notes             String?    @db.Text
  
  // Relaciones
  movements         Movement[]
  preInvoiceItems   PreInvoiceItem[]
  exitNoteItems     ExitNoteItem[]
  entryNoteItems    EntryNoteItem[]
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("batches")
  @@index([batchNumber])
  @@index([itemId])
  @@index([expiryDate])
  @@index([itemId, expiryDate])
  @@index([isActive])
}

// backend/prisma/models/inventory/brand.prisma

enum BrandType {
