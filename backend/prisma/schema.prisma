  // Relación con Transfer (cuando type=TRANSFER)
  transfer         Transfer?

  notes            String?         @db.Text
  
  // Fechas
  receivedAt       DateTime?
  verifiedAt       DateTime?
  
  // Auditoría
  receivedBy       String?
  verifiedBy       String?
  authorizedBy     String?         // Quien autorizó entrada sin OC
  
  createdAt        DateTime        @default(now())
