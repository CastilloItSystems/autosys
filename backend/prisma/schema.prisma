  isVerified      Boolean  @default(false)  // Si fue verificado por un técnico
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([partModelId, vehicleModelId])
  @@map("model_compatibility")
  @@index([partModelId])
  @@index([vehicleModelId])
}

// backend/prisma/models/inventory/movement.prisma

enum MovementType {
  PURCHASE           // Entrada por compra
  SALE               // Salida por venta/consumo
  ADJUSTMENT_IN      // Ajuste entrada
  ADJUSTMENT_OUT     // Ajuste salida
  TRANSFER           // Transferencia entre almacenes
  SUPPLIER_RETURN    // Devolución a proveedor
  WORKSHOP_RETURN    // Devolución de taller
  RESERVATION_RELEASE // Liberación de reserva
  LOAN_OUT           // Salida por préstamo
  LOAN_RETURN        // Entrada por devolución de préstamo
}

model Movement {
  id              String       @id @default(uuid())
  movementNumber  String       @unique
  type            MovementType
  
  itemId          String
  item            Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  // Almacenes origen/destino
  warehouseFromId String?
  warehouseFrom   Warehouse?   @relation("WarehouseFrom", fields: [warehouseFromId], references: [id], onDelete: Restrict)
  
  warehouseToId   String?
  warehouseTo     Warehouse?   @relation("WarehouseTo", fields: [warehouseToId], references: [id], onDelete: Restrict)
  
  quantity        Int
  
  // Inventory Discrepancy Tracking (Variance Analysis)
  snapshotQuantity Int?         // Expected quantity at time of count
  variance        Int?         // Difference detected: countedQuantity - expectedQuantity
  
  // Costos
  unitCost        Decimal?     @db.Decimal(12, 2)
  totalCost       Decimal?     @db.Decimal(12, 2)
  
  // Trazabilidad
  batchId         String?
  batch           Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  
  // Referencias cruzadas
  reference       String?
  purchaseOrderId String?
  workOrderId     String?      // Para vincular con módulo de taller
  reservationId   String?
  exitNoteId      String?
  entryNoteId     String?
  invoiceId       String?
  
  // Para salidas especiales sin factura
  exitType        String?      // "WARRANTY", "LOAN", etc.
  
  notes           String?      @db.Text
  
  // Auditoría
  createdBy       String?
  approvedBy      String?
  approvedAt      DateTime?
  
  movementDate    DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("movements")
  @@index([itemId])
  @@index([type])
  @@index([movementDate])
  @@index([itemId, movementDate])
  @@index([reference])
  @@index([warehouseFromId])
  @@index([warehouseToId])
}

// backend/prisma/models/inventory/pricing.prisma

model Pricing {
  id                String   @id @default(uuid())
  
  itemId            String
  item              Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  costPrice         Decimal  @db.Decimal(12, 2)
  salePrice         Decimal  @db.Decimal(12, 2)
  wholesalePrice    Decimal? @db.Decimal(12, 2)
  
  minMargin         Decimal  @db.Decimal(5, 2) // Porcentaje de margen mínimo (0.00–999.99)
  maxMargin         Decimal  @db.Decimal(5, 2) // Porcentaje de margen máximo
  discountPercentage Decimal? @db.Decimal(5, 2) // Descuento aplicable en porcentaje
  
  // Precios en moneda extranjera (USD) — input del usuario
  costForeign     Decimal  @default(0) @db.Decimal(20,7)  // costoex
  exchangeRate    Decimal  @default(1) @db.Decimal(20,7)  // factor (tasacambio del día)
  costRef         Decimal  @default(0) @db.Decimal(20,7)  // costoref = costForeign × exchangeRate
  costPrevious    Decimal  @default(0) @db.Decimal(20,7)  // costo_ant

  // Impuestos
  taxRateSale     Decimal  @default(0) @db.Decimal(20,7)  // impuesto1 (IVA venta)
  taxRatePurchase Decimal  @default(0) @db.Decimal(20,7)  // cimpuesto1 (IVA compra)

  notes             String?  @db.Text
  isActive          Boolean  @default(true)

  // Relaciones
  tiers             PricingTier[]
  priceLevels       PriceLevel[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([itemId])
  @@map("pricings")
  @@index([itemId])
  @@index([isActive])
}

model PriceLevel {
  id           String  @id @default(uuid())
  pricingId    String
  pricing      Pricing @relation(fields: [pricingId], references: [id], onDelete: Cascade)

  level        Int                                        // 1-8 (precio1ex…precio8ex)
  priceForeign Decimal @default(0) @db.Decimal(20,7)    // precioNex — input del usuario (USD)
  price        Decimal @default(0) @db.Decimal(20,7)    // precioN = priceForeign × exchangeRate
  finalPrice   Decimal @default(0) @db.Decimal(20,7)    // preciofin N = price × (1 + taxRateSale/100)
  utility      Decimal @default(0) @db.Decimal(20,7)    // utilN = ((priceForeign − costForeign) / priceForeign) × 100
  commission   Decimal @default(0) @db.Decimal(20,7)    // comisionN (default 0)

  @@unique([pricingId, level])
  @@map("price_levels")
  @@index([pricingId])
}

model PricingTier {
  id                String   @id @default(uuid())
  
  pricingId         String
  pricing           Pricing  @relation(fields: [pricingId], references: [id], onDelete: Cascade)
  
  minQuantity       Int
  maxQuantity       Int?     // null si es sin límite
  tierPrice         Decimal  @db.Decimal(12, 2)
  discountPercentage Decimal? @db.Decimal(5, 2) // Descuento en este tier
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("pricing_tiers")
  @@index([pricingId])
  @@index([minQuantity])
}


// backend/prisma/models/inventory/purchaseOrder.prisma

enum PurchaseOrderStatus {
  DRAFT       // Borrador
  SENT        // Enviada al proveedor
  PARTIAL     // Recepción parcial
  COMPLETED   // Completada
  CANCELLED   // Cancelada
}

enum PurchaseOrderCurrency {
  USD
  VES
  EUR
}

model PurchaseOrder {
  id              String                @id @default(uuid())
  orderNumber     String                @unique

  // ── Proveedor ──
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  // ── Almacén destino ──
  warehouseId     String
  warehouse       Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  status          PurchaseOrderStatus   @default(DRAFT)

  // ── Moneda y tasa ──
  currency        PurchaseOrderCurrency @default(USD)
  exchangeRate    Decimal?              @db.Decimal(14, 4)   // Tasa BCV del día (VES/USD)

  // ── Condiciones comerciales ──
  paymentTerms    String?               // Ej: "Contado", "Crédito 30 días", "50/50"
  creditDays      Int?                  // Días de crédito (si aplica)
  deliveryTerms   String?               // Ej: "Puesto en almacén", "FOB", "CIF"

  // ── Descuento general (aplicado al subtotal bruto) ──
  discountAmount  Decimal               @default(0) @db.Decimal(12, 2)

  // ── Totales calculados ──
  subtotalBruto   Decimal               @default(0) @db.Decimal(12, 2)  // Suma líneas antes de descuento general
  baseImponible   Decimal               @default(0) @db.Decimal(12, 2)  // Subtotal gravado (IVA 16%)
  baseExenta      Decimal               @default(0) @db.Decimal(12, 2)  // Subtotal exento (IVA 0%)
  taxAmount       Decimal               @default(0) @db.Decimal(12, 2)  // IVA total
  taxRate         Decimal               @default(16) @db.Decimal(5, 2)  // % IVA vigente

  // ── IGTF (Impuesto a Grandes Transacciones Financieras) ──
  igtfApplies     Boolean               @default(false)                 // Toggle: pago en divisas
  igtfRate        Decimal               @default(3) @db.Decimal(5, 2)   // % IGTF vigente
  igtfAmount      Decimal               @default(0) @db.Decimal(12, 2)  // Monto IGTF calculado

  // ── Total final ──
  total           Decimal               @default(0) @db.Decimal(12, 2)  // subtotal - descuento + IVA + IGTF

  notes           String?               @db.Text

  // ── Relaciones ──
  items           PurchaseOrderItem[]
  entryNotes      EntryNote[]

  // ── Fechas ──
  orderDate       DateTime              @default(now())
  expectedDate    DateTime?

  // ── Auditoría ──
  createdBy       String?
  approvedBy      String?
  approvedAt      DateTime?

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("purchase_orders")
  @@index([orderNumber])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}


// backend/prisma/models/inventory/purchaseOrderItem.prisma

enum TaxType {
  IVA       // Gravado — actualmente 16%
  EXEMPT    // Exento (0%)
  REDUCED   // Reducido (8%) — por si aplica en futuro
}

model PurchaseOrderItem {
  id                String          @id @default(uuid())

  purchaseOrderId   String
  purchaseOrder     PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  itemId            String
  item              Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  itemName         String?          @db.VarChar(255)
  // ── Cantidades ──
  quantityOrdered   Int
  quantityReceived  Int             @default(0)
  quantityPending   Int             // Calculado: ordered - received

  // ── Precio ──
  unitCost          Decimal         @db.Decimal(12, 2)

  // ── Descuento por línea ──
  discountPercent   Decimal         @default(0) @db.Decimal(5, 2)   // % descuento
  discountAmount    Decimal         @default(0) @db.Decimal(12, 2)  // Monto desc. calculado

  // ── Impuesto por línea ──
  taxType           TaxType         @default(IVA)                   // IVA, Exento, Reducido
  taxRate           Decimal         @default(16) @db.Decimal(5, 2)  // % según taxType
  taxAmount         Decimal         @default(0) @db.Decimal(12, 2)  // IVA calculado para esta línea

  // ── Subtotal línea (qty × unitCost - descuento) ──
  subtotal          Decimal         @db.Decimal(12, 2)

  // ── Total línea (subtotal + taxAmount) ──
  totalLine         Decimal         @default(0) @db.Decimal(12, 2)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("purchase_order_items")
  @@index([purchaseOrderId])
  @@index([itemId])
}


