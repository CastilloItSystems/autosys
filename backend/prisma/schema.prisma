// backend/prisma/models/workshop/vehicleReception.prisma
// Recepción formal del vehículo en el taller.
// Registra el estado físico del vehículo al ingresar.
// Puede generarse desde una cita o directamente (walk-in).

enum FuelLevel {
  EMPTY          // Vacío
  QUARTER        // 1/4
  HALF           // 1/2
  THREE_QUARTERS // 3/4
  FULL           // Lleno
}

enum ReceptionStatus {
  OPEN             // Abierta / vehículo recibido
  DIAGNOSING       // Técnico realizando diagnóstico
  QUOTED           // Diagnóstico listo, cotización generada
  CONVERTED_TO_SO  // Convertida en Orden de Trabajo
  CANCELLED        // Cancelada
}

model VehicleReception {
  id    String @id @default(cuid())
  folio String // REC-0001 auto-generado por empresa

  // Cliente y vehículo
  customerId        String
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerVehicleId String?
  customerVehicle   CustomerVehicle? @relation(fields: [customerVehicleId], references: [id], onDelete: SetNull)

  // Snapshot del vehículo al ingresar
  vehiclePlate String?
  vehicleDesc  String? // "Toyota Hilux 2021 Gris"

  // Datos de ingreso
  mileageIn  Int?
  fuelLevel  FuelLevel?

  // Motivo de Ingreso
  ingressMotiveId String?
  ingressMotive   IngressMotive? @relation(fields: [ingressMotiveId], references: [id], onDelete: SetNull)

  // Inventario de accesorios y condición
  accessories      Json?    // Ej: ["gata", "llanta de repuesto", "radio", "manual"]
  hasPreExistingDamage Boolean @default(false)
  damageNotes      String? @db.Text // Descripción de daños pre-existentes

  // Descripción del cliente de lo que necesita
  clientDescription String? @db.Text

  // Autorización de ingreso
  authorizationName  String? // Nombre de quien autoriza (puede ser el mismo cliente)
  authorizationPhone String?

  // Entrega estimada al recibir
  estimatedDelivery DateTime?

  // Estado del ciclo de vida de la recepción
  status    ReceptionStatus @default(OPEN)

  // Autorización digital
  clientSignature      String?  // URL de firma digital del cliente
  diagnosticAuthorized Boolean  @default(false) // Cliente autorizó diagnóstico

  // Asesor que recibe
  advisorId String? // userId

  // Cita de origen (opcional - puede ser walk-in)
  appointmentId String?
  appointment   ServiceAppointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  // Multi-tenancy y auditoría
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación inversa: la OT generada desde esta recepción
  serviceOrder ServiceOrder?

  // Checklist dinámico
  checklistTemplateId String?
  checklistTemplate   ChecklistTemplate?  @relation(fields: [checklistTemplateId], references: [id], onDelete: SetNull)
  checklistResponses  ChecklistResponse[]

  // Diagnóstico desacoplado
  serviceDiagnosis ServiceDiagnosis?

  // Daños y fotos detalladas
  damages ReceptionDamage[]
  photos  ReceptionPhoto[]

  // Sucursal
  branchId String?
  branch   WorkshopBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([empresaId, folio])
  @@index([empresaId])
  @@index([customerId])
  @@index([customerVehicleId])
  @@index([appointmentId])
  @@index([createdAt])
  @@map("workshop_receptions")
}


// backend/prisma/models/workshop/workshopAttachment.prisma
// Documento adjunto polimórfico para cualquier entidad del módulo de taller.
// Permite adjuntar archivos a OTs, recepciones, garantías, diagnósticos, etc.

enum AttachmentEntityType {
  SERVICE_ORDER         // Orden de trabajo
  VEHICLE_RECEPTION     // Recepción de vehículo
  SERVICE_DIAGNOSIS     // Diagnóstico técnico
  WORKSHOP_WARRANTY     // Garantía
  SERVICE_APPOINTMENT   // Cita
  QUALITY_CHECK         // Control de calidad
}

enum AttachmentFileType {
  IMAGE    // jpg, png, webp
  VIDEO    // mp4, mov
  PDF      // Documentos PDF
  DOCUMENT // doc, xls, etc.
  OTHER
}

model WorkshopAttachment {
  id         String @id @default(cuid())

  entityType AttachmentEntityType
  entityId   String               // ID de la entidad relacionada (no FK - relación polimórfica)

  fileType    AttachmentFileType @default(OTHER)
  url         String
  name        String             // Nombre descriptivo del archivo
  description String?            @db.Text
  mimeType    String?            // Ej: "image/jpeg", "application/pdf"
  sizeBytes   Int?               // Tamaño en bytes

  uploadedBy  String             // userId
  empresaId   String
  empresa     Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([entityType, entityId]) // Principal: buscar adjuntos de una entidad
  @@index([empresaId])
  @@map("workshop_attachments")
}


// backend/prisma/models/workshop/workshopAuditLog.prisma
// Auditoría general polimórfica del módulo de taller.
// Registra cualquier acción crítica: cambios de estado, descuentos, reaperturas, etc.

enum AuditEntityType {
  SERVICE_ORDER
  VEHICLE_RECEPTION
  SERVICE_APPOINTMENT
  WORKSHOP_WARRANTY
  WORKSHOP_REWORK
  QUALITY_CHECK
  LABOR_TIME
  SERVICE_ORDER_MATERIAL
  VEHICLE_DELIVERY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  REOPEN
  APPROVE
  REJECT
  CANCEL
  ASSIGN
  DELIVER
}

model WorkshopAuditLog {
  id         String @id @default(cuid())

  entityType AuditEntityType
  entityId   String

  action     AuditAction
  previousValue Json?   // Estado anterior (snapshot)
  newValue      Json?   // Estado nuevo (snapshot)

  description String? @db.Text  // Descripción legible del cambio
  userId      String             // Quien ejecutó la acción
  userIp      String?            // IP del usuario

  empresaId   String
  empresa     Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([entityType, entityId]) // Principal: historial de una entidad
  @@index([empresaId, createdAt]) // Auditoría por empresa en el tiempo
  @@index([userId])
  @@map("workshop_audit_logs")
}


// backend/prisma/models/workshop/workshopBay.prisma
