// backend/prisma/models/inventory/warehouse.prisma

enum WarehouseType {
  PRINCIPAL  // Almacén principal
  SUCURSAL   // Sucursal/Tienda
  TRANSITO   // Almacén de tránsito
}

model Warehouse {
  id          String        @id @default(uuid())
  code        String
  name        String
  type        WarehouseType @default(PRINCIPAL)
  address     String?
  isActive    Boolean       @default(true)
  
  // Multi-tenancy
  empresaId   String
  empresa     Empresa       @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relaciones
  stocks          Stock[]
  movementsFrom   Movement[]    @relation("WarehouseFrom")
  movementsTo     Movement[]    @relation("WarehouseTo")
  orders          Order[]
  preInvoices     PreInvoice[]
  exitNotes       ExitNote[]
  entryNotes      EntryNote[]
  purchaseOrders  PurchaseOrder[]
  adjustments     Adjustment[]
  cycleCounts     CycleCount[]
  reconciliations Reconciliation[]
  loans           Loan[]
  reservations    Reservation[]
  stockAlerts     StockAlert[]
  returnOrders    ReturnOrder[]
  serialNumbers   SerialNumber[]
  transfersFrom   Transfer[]     @relation("TransferFrom")
  transfersTo     Transfer[]     @relation("TransferTo")
  
  // Auditoría
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([empresaId, code])
  @@map("warehouses")
  @@index([type])
  @@index([isActive])
  @@index([empresaId])
}

enum MembershipStatus {
  invited
  active
  suspended
}

model Membership {
  id          String               @id @default(cuid())

  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  empresaId   String
  empresa     Empresa              @relation(fields: [empresaId], references: [id_empresa], onDelete: Cascade)

  roleId      String
  role        CompanyRole          @relation(fields: [roleId], references: [id], onDelete: Restrict)

  status      MembershipStatus     @default(active)

  assignedBy  String?
  assignedAt  DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  permissions MembershipPermission[]

  @@unique([userId, empresaId])
  @@index([userId])
  @@index([empresaId])
  @@index([roleId])
  @@map("memberships")
}

enum PermissionAction {
  GRANT
  REVOKE
}

model MembershipPermission {
  id            String            @id @default(cuid())

  membershipId  String
  membership    Membership        @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  permissionId  String
  permission    Permission        @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  action        PermissionAction  @default(GRANT)
  reason        String?
  grantedBy     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([membershipId, permissionId])
  @@index([permissionId])
  @@map("membership_permissions")
}

model Permission {
  id                    String                  @id @default(cuid())
  code                  String                  @unique
  description           String?
  createdAt             DateTime                @default(now())

  rolePermissions       RolePermission[]
  membershipPermissions MembershipPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId        String
  permissionId  String

  role          CompanyRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// backend/prisma/models/sales/invoice.prisma

enum InvoiceStatus {
  ACTIVE     // Activa
  CANCELLED  // Anulada
  CREDITED   // Con nota de crédito
}

model Invoice {
  id                 String        @id @default(uuid())
  invoiceNumber      String        @unique
  fiscalNumber       String?       @unique // Número de control fiscal
  status             InvoiceStatus @default(ACTIVE)

  empresaId          String
  empresa            Empresa       @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  // Relación con PreInvoice
  preInvoiceId       String        @unique
  preInvoice         PreInvoice    @relation(fields: [preInvoiceId], references: [id], onDelete: Restrict)

  // Relación con Payment (el pago que generó esta factura)
  paymentId          String        @unique
  payment            Payment       @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  customerId         String
  customer           Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // Relaciones
  items              InvoiceItem[]

  // Workshop: OT facturada con esta invoice
  serviceOrder       ServiceOrder?

  // ── Moneda ──
  currency           OrderCurrency @default(USD)
  exchangeRate       Decimal?      @db.Decimal(14, 4)

  // ── Descuento general ──
  discountAmount     Decimal       @default(0) @db.Decimal(12, 2)

  // ── Totales fiscales ──
  subtotalBruto      Decimal       @default(0) @db.Decimal(12, 2)
  baseImponible      Decimal       @default(0) @db.Decimal(12, 2)
  baseExenta         Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount          Decimal       @default(0) @db.Decimal(12, 2)
  taxRate            Decimal       @default(16) @db.Decimal(5, 2)

  // ── IGTF ──
  igtfApplies        Boolean       @default(false)
  igtfRate           Decimal       @default(3) @db.Decimal(5, 2)
  igtfAmount         Decimal       @default(0) @db.Decimal(12, 2)

  // ── Total ──
  total              Decimal       @default(0) @db.Decimal(12, 2)

  // ── Legacy ──
  subtotal           Decimal       @default(0) @db.Decimal(12, 2)
  discount           Decimal       @default(0) @db.Decimal(12, 2)
  tax                Decimal       @default(0) @db.Decimal(12, 2)

  notes              String?       @db.Text

  // Fiscal
  invoiceDate        DateTime      @default(now())

  // Auditoría
  issuedBy           String?

  // Anulación
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?       @db.Text

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("invoices")
  @@index([invoiceNumber])
  @@index([fiscalNumber])
  @@index([customerId])
  @@index([preInvoiceId])
  @@index([status])
  @@index([invoiceDate])
  @@index([empresaId])
}


// backend/prisma/models/sales/invoiceItem.prisma

model InvoiceItem {
  id              String    @id @default(uuid())

  invoiceId       String
  invoice         Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  itemId          String?
  item            Item?     @relation(fields: [itemId], references: [id], onDelete: SetNull)

  // ── Snapshot ──
  itemName        String?   @db.VarChar(255)

  quantity        Int
  unitPrice       Decimal   @db.Decimal(12, 2)

  // ── Descuento por línea ──
  discountPercent Decimal   @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(12, 2)

  // ── Impuesto por línea ──
  taxType         TaxType   @default(IVA)
  taxRate         Decimal   @default(16) @db.Decimal(5, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(12, 2)

  // ── Subtotal y total ──
  subtotal        Decimal   @db.Decimal(12, 2)
  totalLine       Decimal   @default(0) @db.Decimal(12, 2)

  // ── Legacy ──
  discount        Decimal   @default(0) @db.Decimal(12, 2)
  tax             Decimal   @default(0) @db.Decimal(12, 2)

  // Trazabilidad
  batchId         String?
  serialNumberId  String?

  createdAt       DateTime  @default(now())

  @@map("invoice_items")
  @@index([invoiceId])
  @@index([itemId])
}


// backend/prisma/models/sales/order.prisma

enum OrderStatus {
  DRAFT              // Borrador
  PENDING_APPROVAL   // Pendiente de aprobación
  APPROVED           // Aprobado
  CANCELLED          // Cancelado
}

enum OrderCurrency {
  USD
  VES
  EUR
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  status          OrderStatus   @default(DRAFT)

  empresaId       String
  empresa         Empresa       @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  // Relaciones
  items           OrderItem[]

  // ── Moneda y tasa ──
  currency          OrderCurrency @default(USD)
  exchangeRate      Decimal?      @db.Decimal(14, 4)
  exchangeRateSource String?      // 'BCV_AUTO' | 'MANUAL'

  // ── Condiciones comerciales ──
  paymentTerms      String?
  creditDays        Int?
  deliveryTerms     String?

  // ── Descuento general ──
  discountAmount    Decimal       @default(0) @db.Decimal(12, 2)

  // ── Totales fiscales ──
  subtotalBruto     Decimal       @default(0) @db.Decimal(12, 2)
  baseImponible     Decimal       @default(0) @db.Decimal(12, 2)
  baseExenta        Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal       @default(0) @db.Decimal(12, 2)
  taxRate           Decimal       @default(16) @db.Decimal(5, 2)

  // ── IGTF ──
  igtfApplies       Boolean       @default(false)
  igtfRate          Decimal       @default(3) @db.Decimal(5, 2)
  igtfAmount        Decimal       @default(0) @db.Decimal(12, 2)

  // ── Total final ──
  total             Decimal       @default(0) @db.Decimal(12, 2)

  // ── Campos legacy (mantener por compatibilidad) ──
  subtotal          Decimal       @default(0) @db.Decimal(12, 2)
  discount          Decimal       @default(0) @db.Decimal(12, 2)
  tax               Decimal       @default(0) @db.Decimal(12, 2)

  notes             String?       @db.Text

  // Fechas
  orderDate         DateTime      @default(now())
  approvedAt        DateTime?

  // Auditoría
  createdBy         String?
  approvedBy        String?

  // Relación 1 a 1 con Pre-factura
  preInvoice        PreInvoice?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("orders")
  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([orderDate])
  @@index([empresaId])
}


// backend/prisma/models/sales/orderItem.prisma

model OrderItem {
  id              String    @id @default(uuid())

  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemId          String
  item            Item      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  // ── Snapshot del nombre ──
  itemName        String?   @db.VarChar(255)

  quantity        Int
  unitPrice       Decimal   @db.Decimal(12, 2)

  // ── Descuento por línea ──
  discountPercent Decimal   @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(12, 2)

  // ── Impuesto por línea ──
  taxType         TaxType   @default(IVA)
  taxRate         Decimal   @default(16) @db.Decimal(5, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(12, 2)

  // ── Subtotal y total línea ──
  subtotal        Decimal   @db.Decimal(12, 2)
  totalLine       Decimal   @default(0) @db.Decimal(12, 2)

  // ── Legacy ──
  discount        Decimal   @default(0) @db.Decimal(12, 2)

  notes           String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("order_items")
  @@index([orderId])
  @@index([itemId])
}


// backend/prisma/models/sales/payment.prisma

enum PaymentMethod {
  CASH            // Efectivo
  TRANSFER        // Transferencia
  CARD            // Tarjeta
  MOBILE_PAYMENT  // Pago móvil
  CHECK           // Cheque
  CREDIT          // Crédito
  MIXED           // Mixto
}

enum PaymentStatus {
  PENDING    // Pendiente
  COMPLETED  // Completado
  CANCELLED  // Cancelado
  REFUNDED   // Reembolsado
}

model Payment {
  id                String        @id @default(uuid())
  paymentNumber     String        @unique
  status            PaymentStatus @default(PENDING)

  // ── Multi-tenancy ──
  empresaId         String
  empresa           Empresa       @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  // ── Relación con PreInvoice ──
  preInvoiceId      String
  preInvoice        PreInvoice    @relation(fields: [preInvoiceId], references: [id], onDelete: Restrict)

  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // ── Detalles del pago ──
  method            PaymentMethod
  amount            Decimal       @db.Decimal(12, 2)

  // ── Moneda ──
  currency          OrderCurrency @default(USD)
  exchangeRate      Decimal?      @db.Decimal(14, 4)

  // ── IGTF (si paga en divisas) ──
  igtfApplies       Boolean       @default(false)
  igtfAmount        Decimal       @default(0) @db.Decimal(12, 2)
  totalWithIgtf     Decimal       @default(0) @db.Decimal(12, 2)

  // ── Para pagos mixtos ──
  details           Json?         // [{ method: "CASH", amount: 100, reference: "..." }, ...]

  reference         String?       // Número de referencia
  notes             String?       @db.Text

  // ── Auditoría ──
  processedBy       String?
  processedAt       DateTime      @default(now())

  // ── Relación 1 a 1 con Factura ──
  invoice           Invoice?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("payments")
  @@index([paymentNumber])
  @@index([customerId])
  @@index([preInvoiceId])
  @@index([status])
  @@index([processedAt])
  @@index([empresaId])
}


// backend/prisma/models/sales/preInvoice.prisma

enum PreInvoiceStatus {
  PENDING_PREPARATION  // Pendiente de preparación
  IN_PREPARATION       // En preparación
  READY_FOR_PAYMENT    // Listo para pago
  PAID                 // Pagado
  CANCELLED            // Cancelado
}

model PreInvoice {
  id                  String            @id @default(uuid())
  preInvoiceNumber    String            @unique
  status              PreInvoiceStatus  @default(PENDING_PREPARATION)

  empresaId           String
  empresa             Empresa           @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  // Relación 1 a 1 con Order (nullable para permitir SO también)
  orderId             String?           @unique
  order               Order?            @relation(fields: [orderId], references: [id], onDelete: Restrict)

  // FASE 2: Relación 1 a 1 con ServiceOrder (para workshop invoicing)
  serviceOrderId      String?           @unique
  serviceOrder        ServiceOrder?     @relation("PreInvoiceServiceOrder", fields: [serviceOrderId], references: [id], onDelete: Restrict)

  customerId          String
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // Warehouse nullable para path de ServiceOrder (workshop tiene su propia ubicación)
  warehouseId         String?
  warehouse           Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  // Relaciones
  items               PreInvoiceItem[]

  // ── Moneda y tasa ──
  currency            OrderCurrency     @default(USD)
  exchangeRate        Decimal?          @db.Decimal(14, 4)

  // ── Descuento general ──
  discountAmount      Decimal           @default(0) @db.Decimal(12, 2)

  // ── Totales fiscales ──
  subtotalBruto       Decimal           @default(0) @db.Decimal(12, 2)
  baseImponible       Decimal           @default(0) @db.Decimal(12, 2)
  baseExenta          Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal           @default(0) @db.Decimal(12, 2)
  taxRate             Decimal           @default(16) @db.Decimal(5, 2)

  // ── IGTF ──
  igtfApplies         Boolean           @default(false)
  igtfRate            Decimal           @default(3) @db.Decimal(5, 2)
  igtfAmount          Decimal           @default(0) @db.Decimal(12, 2)

  // ── Total final ──
  total               Decimal           @default(0) @db.Decimal(12, 2)

  // ── Campos legacy ──
  subtotal            Decimal           @default(0) @db.Decimal(12, 2)
  discount            Decimal           @default(0) @db.Decimal(12, 2)
  tax                 Decimal           @default(0) @db.Decimal(12, 2)

  notes               String?           @db.Text

  // Control de flujo
  preparedAt          DateTime?
  paidAt              DateTime?
  preparedBy          String?

  // Relaciones 1 a 1
  exitNote            ExitNote?
  invoice             Invoice?

  payments            Payment[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("pre_invoices")
  @@index([preInvoiceNumber])
  @@index([customerId])
  @@index([status])
  @@index([empresaId])
}


// backend/prisma/models/sales/preInvoiceItem.prisma

model PreInvoiceItem {
  id              String        @id @default(uuid())

  preInvoiceId    String
  preInvoice      PreInvoice    @relation(fields: [preInvoiceId], references: [id], onDelete: Cascade)

  itemId          String?
  item            Item?         @relation(fields: [itemId], references: [id], onDelete: SetNull)

  // ── Snapshot ──
  itemName        String?       @db.VarChar(255)

  quantity        Int
  unitPrice       Decimal       @db.Decimal(12, 2)

  // ── Descuento por línea ──
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)

  // ── Impuesto por línea ──
  taxType         TaxType       @default(IVA)
  taxRate         Decimal       @default(16) @db.Decimal(5, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)

  // ── Subtotal y total línea ──
  subtotal        Decimal       @db.Decimal(12, 2)
  totalLine       Decimal       @default(0) @db.Decimal(12, 2)

  // ── Legacy ──
  discount        Decimal       @default(0) @db.Decimal(12, 2)

  // Trazabilidad
  batchId         String?
  batch           Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)

  serialNumberId  String?
