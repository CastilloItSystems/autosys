  notes               String? @db.Text
  createdAt           DateTime @default(now())
  
  @@unique([loanId, itemId])
  @@index([loanId])
  @@index([itemId])
  @@map("loan_items")
}

// backend/prisma/models/inventory/model.prisma

enum ModelType {
  VEHICLE       // Modelo de vehículo (Hilux 2020)
  PART          // Modelo de producto (PH3614, Lysol 500ml)
  GENERIC       // Genérico
}

model Model {
  id          String    @id @default(uuid())
  
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  brandId     String
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Restrict)
  
  code        String?   // Código del modelo
  name        String    // Nombre del modelo
  year        Int?      // Año (principalmente para vehículos)
  
  type        ModelType @default(PART)
  description String?
  
  // Especificaciones técnicas (JSON flexible)
  specifications Json?   // Ej: { "viscosity": "10W-40", "capacity": "500ml" }
  
  isActive    Boolean   @default(true)
  
  // Compatibilidad (para productos que aplique)
  compatibleVehicles ModelCompatibility[] @relation("PartModel")
  compatibleParts    ModelCompatibility[] @relation("VehicleModel")
  
  // Relaciones
  items       Item[]
  
  // Auditoría
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([empresaId, brandId, code, name, year, type])
  @@map("models")
  @@index([brandId])
  @@index([code])
  @@index([type])
  @@index([isActive])
  @@index([empresaId])
}

// backend/prisma/models/inventory/modelCompatibility.prisma

model ModelCompatibility {
  id              String   @id @default(uuid())
  
  // Modelo del producto (repuesto, aceite, etc)
  partModelId     String
  partModel       Model    @relation("PartModel", fields: [partModelId], references: [id], onDelete: Cascade)
  
  // Modelo del vehículo compatible
  vehicleModelId  String
  vehicleModel    Model    @relation("VehicleModel", fields: [vehicleModelId], references: [id], onDelete: Cascade)
  
  notes           String?
  isVerified      Boolean  @default(false)  // Si fue verificado por un técnico
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([partModelId, vehicleModelId])
  @@map("model_compatibility")
  @@index([partModelId])
  @@index([vehicleModelId])
}

// backend/prisma/models/inventory/movement.prisma

enum MovementType {
  PURCHASE           // Entrada por compra
  SALE               // Salida por venta/consumo
  ADJUSTMENT_IN      // Ajuste entrada
  ADJUSTMENT_OUT     // Ajuste salida
  TRANSFER           // Transferencia entre almacenes
  SUPPLIER_RETURN    // Devolución a proveedor
  WORKSHOP_RETURN    // Devolución de taller
  RESERVATION_RELEASE // Liberación de reserva
  LOAN_OUT           // Salida por préstamo
  LOAN_RETURN        // Entrada por devolución de préstamo
}

model Movement {
  id              String       @id @default(uuid())
  movementNumber  String       @unique
  type            MovementType
  
  itemId          String
  item            Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  // Almacenes origen/destino
  warehouseFromId String?
  warehouseFrom   Warehouse?   @relation("WarehouseFrom", fields: [warehouseFromId], references: [id], onDelete: Restrict)
  
  warehouseToId   String?
  warehouseTo     Warehouse?   @relation("WarehouseTo", fields: [warehouseToId], references: [id], onDelete: Restrict)
  
  quantity        Int
  
  // Inventory Discrepancy Tracking (Variance Analysis)
  snapshotQuantity Int?         // Expected quantity at time of count
  variance        Int?         // Difference detected: countedQuantity - expectedQuantity
  
  // Costos
  unitCost        Decimal?     @db.Decimal(12, 2)
  totalCost       Decimal?     @db.Decimal(12, 2)
  
  // Trazabilidad
  batchId         String?
  batch           Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  
  // Referencias cruzadas
  reference       String?
  purchaseOrderId String?
  workOrderId     String?      // Para vincular con módulo de taller
  reservationId   String?
  exitNoteId      String?
  entryNoteId     String?
  invoiceId       String?
  
  // Para salidas especiales sin factura
  exitType        String?      // "WARRANTY", "LOAN", etc.
  
  notes           String?      @db.Text
  
  // Auditoría
  createdBy       String?
  approvedBy      String?
  approvedAt      DateTime?
  
  movementDate    DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("movements")
  @@index([itemId])
  @@index([type])
  @@index([movementDate])
  @@index([reference])
  @@index([warehouseFromId])
  @@index([warehouseToId])
}

// backend/prisma/models/inventory/pricing.prisma

model Pricing {
  id                String   @id @default(uuid())
  
  itemId            String
  item              Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  costPrice         Decimal  @db.Decimal(12, 2)
  salePrice         Decimal  @db.Decimal(12, 2)
  wholesalePrice    Decimal? @db.Decimal(12, 2)
  
  minMargin         Int      // Porcentaje de margen mínimo
  maxMargin         Int      // Porcentaje de margen máximo
  discountPercentage Int?    // Descuento aplicable en porcentaje
  
  notes             String?  @db.Text
  isActive          Boolean  @default(true)
  
  // Relaciones
  tiers             PricingTier[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([itemId])
  @@map("pricings")
  @@index([itemId])
  @@index([isActive])
}

model PricingTier {
  id                String   @id @default(uuid())
  
  pricingId         String
  pricing           Pricing  @relation(fields: [pricingId], references: [id], onDelete: Cascade)
  
  minQuantity       Int
  maxQuantity       Int?     // null si es sin límite
  tierPrice         Decimal  @db.Decimal(12, 2)
  discountPercentage Int?    // Descuento en este tier
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("pricing_tiers")
  @@index([pricingId])
  @@index([minQuantity])
}


// backend/prisma/models/inventory/purchaseOrder.prisma

enum PurchaseOrderStatus {
  DRAFT       // Borrador
  SENT        // Enviada al proveedor
  PARTIAL     // Recepción parcial
  COMPLETED   // Completada
  CANCELLED   // Cancelada
}

model PurchaseOrder {
  id            String              @id @default(uuid())
  orderNumber   String              @unique
  
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  
  warehouseId   String
  warehouse     Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  status        PurchaseOrderStatus @default(DRAFT)
  
  // Totales
  subtotal      Decimal             @default(0) @db.Decimal(12, 2)
  tax           Decimal             @default(0) @db.Decimal(12, 2)
  total         Decimal             @default(0) @db.Decimal(12, 2)
  
  notes         String?             @db.Text
  
  // Relaciones
  items         PurchaseOrderItem[]
  entryNotes    EntryNote[]
  
  // Fechas
  orderDate     DateTime            @default(now())
  expectedDate  DateTime?
  
  // Auditoría
  createdBy     String?
  approvedBy    String?
  approvedAt    DateTime?
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("purchase_orders")
  @@index([orderNumber])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}

// backend/prisma/models/inventory/purchaseOrderItem.prisma

model PurchaseOrderItem {
  id                String        @id @default(uuid())
  
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  itemId            String
  item              Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  quantityOrdered   Int
  quantityReceived  Int           @default(0)
  quantityPending   Int           // Calculado: ordered - received
  
  unitCost          Decimal       @db.Decimal(12, 2)
  subtotal          Decimal       @db.Decimal(12, 2)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("purchase_order_items")
  @@index([purchaseOrderId])
  @@index([itemId])
}

// backend/prisma/models/inventory/reconciliation.prisma

enum ReconciliationStatus {
  DRAFT
  IN_PROGRESS
  APPROVED
  APPLIED
  REJECTED
  CANCELLED

  @@map("reconciliation_status")
}

enum ReconciliationSource {
  CYCLE_COUNT
  PHYSICAL_INVENTORY
  SYSTEM_ERROR
  ADJUSTMENT
  OTHER

  @@map("reconciliation_source")
}

model Reconciliation {
  id                    String                   @id @default(uuid())
  reconciliationNumber  String                   @unique
  warehouseId           String
  warehouse             Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  status                ReconciliationStatus     @default(DRAFT)
  source                ReconciliationSource
