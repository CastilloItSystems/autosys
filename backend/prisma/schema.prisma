generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model AuditLog {
  id        String   @id @default(cuid())
  entity    String   // Nombre de la tabla (Ej: "User", "Empresa")
  entityId  String   // ID del registro afectado
  action    String   // "CREATE", "UPDATE", "DELETE", etc.
  
  userId    String?  // Usuario que realizó la acción
  user      User?    @relation(fields: [userId], references: [id])
  
  changes   Json     // Guardará el estado anterior y nuevo: { before: {...}, after: {...} }
  metadata  Json?    // Para guardar IP, navegador, etc.
  
  createdAt DateTime @default(now())

  @@index([entity, entityId]) // Búsqueda rápida por registro
  @@index([userId])           // Búsqueda rápida por usuario
}
model Empresa {
  id_empresa    String   @id @default(cuid())
  nombre        String
  direccion     String?
  telefonos     String?
  fax           String?
  numerorif     String?
  numeronit     String?
  website       String?
  email         String?
  contacto      String?
  predeter      Boolean  @default(false)
  soporte1      String?
  soporte2      String?
  soporte3      String?
  data_usaweb   Boolean  @default(false)
  data_servidor String?
  data_usuario  String?
  data_password String?
  data_port     String?
  licencia      String?
  historizada   Boolean  @default(false)
  masinfo       String?
  usa_prefijo   Boolean  @default(false)
  name_prefijo  String?
  dprefijobd    String?
  dprefijosrv   String?
  dprefijousr   String?
  eliminado     Boolean  @default(false)
  users         User[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}model User {
  id           String    @id @default(cuid())
  img          String?
  nombre       String
  correo       String    @unique
  telefono     String?
  password     String
  rol          Role      @default(lectura)
  departamento String[]
  acceso       Access    @default(ninguno)
  empresas     Empresa[]
  estado       UserStatus @default(activo)
  eliminado    Boolean   @default(false)
  online       Boolean   @default(false)
  fcmTokens    String[]
  google       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    AuditLog[]
}

enum UserStatus {
  pendiente
  activo
  suspendido
}

enum Role {
  superAdmin
  admin
  operador
  user
  lectura
}

enum Access {
  limitado
  completo
  ninguno
}
