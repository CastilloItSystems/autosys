// backend/prisma/models/workshop/ingressMotive.prisma
// Motivos de ingreso al taller.

model IngressMotive {
  id          String   @id @default(cuid())
  code        String
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  receptions VehicleReception[]

  @@unique([empresaId, code])
  @@index([empresaId])
  @@index([isActive])
  @@map("workshop_ingress_motives")
}
