// backend/prisma/models/workshop/serviceType.prisma
// Catálogo de tipos de servicio del taller.
// Ej: Mantenimiento preventivo, correctivo, diagnóstico, cambio de aceite, etc.

model ServiceType {
  id          String  @id @default(cuid())
  code        String
  name        String
  description String? @db.Text

  isActive  Boolean @default(true)

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  // Relaciones
  appointments  ServiceAppointment[]
  serviceOrders ServiceOrder[]
  operations    WorkshopOperation[]

  @@unique([empresaId, code])
  @@index([empresaId])
  @@index([isActive])
  @@map("workshop_service_types")
}
