// backend/prisma/models/workshop/workshopBranch.prisma
// Sucursal del taller. Permite multi-sucursal dentro de una empresa.
// Las entidades operativas (OT, recepción, cita) pueden vincularse a una sucursal.

model WorkshopBranch {
  id          String @id @default(cuid())
  code        String
  name        String
  address     String?
  phone       String?
  managerUserId String?  // userId del jefe de taller / encargado
  isActive    Boolean @default(true)

  empresaId   String
  empresa     Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Entidades asociadas
  bays              WorkshopBay[]
  serviceOrders     ServiceOrder[]
  appointments      ServiceAppointment[]
  receptions        VehicleReception[]

  @@unique([empresaId, code])
  @@index([empresaId])
  @@index([isActive])
  @@map("workshop_branches")
}
