// backend/prisma/models/workshop/technicianSpecialty.prisma
// Especialidades técnicas (ej. Electricista, Mecánico General, Pintor)

model TechnicianSpecialty {
  id          String   @id @default(cuid())
  code        String
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Operaciones que requieren esta especialidad
  requiredInOperations WorkshopOperation[]

  @@unique([empresaId, code])
  @@index([empresaId])
  @@index([isActive])
  @@map("workshop_technician_specialties")
}
