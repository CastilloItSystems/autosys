// backend/prisma/models/workshop/vehicleDelivery.prisma

model VehicleDelivery {
  id             String       @id @default(cuid())
  serviceOrderId String       @unique
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  
  deliveredAt    DateTime     @default(now())
  deliveredBy    String       // userId
  receivedByName String?
  clientConformity Boolean    @default(true)
  clientSignature String?     // URL de la firma si aplica
  observations   String?      @db.Text
  nextVisitDate  DateTime?

  empresaId      String
  empresa        Empresa      @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([empresaId])
  @@map("workshop_vehicle_deliveries")
}
