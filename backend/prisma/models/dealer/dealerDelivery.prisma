enum DealerDeliveryStatus {
  SCHEDULED
  READY
  DELIVERED
  CANCELLED
}

model DealerDelivery {
  id                  String                @id @default(uuid())

  empresaId            String
  empresa              Empresa               @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  dealerUnitId         String
  dealerUnit           DealerUnit            @relation("DealerUnitDelivery", fields: [dealerUnitId], references: [id], onDelete: Restrict)

  deliveryNumber       String
  status               DealerDeliveryStatus  @default(SCHEDULED)

  customerName         String
  customerDocument     String?
  customerPhone        String?
  customerEmail        String?

  scheduledAt          DateTime
  deliveredAt          DateTime?
  advisorName          String?
  checklistCompleted   Boolean               @default(false)
  documentsSigned      Boolean               @default(false)
  accessoriesDelivered Boolean               @default(false)
  observations         String?
  actNumber            String?
  isActive             Boolean               @default(true)

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@map("dealer_deliveries")
  @@index([empresaId])
  @@index([dealerUnitId])
  @@index([status])
  @@index([isActive])
  @@index([scheduledAt])
  @@unique([empresaId, deliveryNumber])
}
