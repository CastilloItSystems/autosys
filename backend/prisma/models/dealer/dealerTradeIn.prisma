enum DealerTradeInStatus {
  PENDING
  INSPECTED
  VALUED
  APPROVED
  REJECTED
  APPLIED
}

model DealerTradeIn {
  id                 String               @id @default(uuid())

  empresaId           String
  empresa             Empresa              @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  targetDealerUnitId  String?
  targetDealerUnit    DealerUnit?          @relation("TradeInTargetUnit", fields: [targetDealerUnitId], references: [id], onDelete: SetNull)

  tradeInNumber       String
  status              DealerTradeInStatus  @default(PENDING)

  customerName        String
  customerDocument    String?
  customerPhone       String?
  customerEmail       String?

  vehicleBrand        String
  vehicleModel        String?
  vehicleYear         Int?
  vehicleVersion      String?
  vehicleVin          String?
  vehiclePlate        String?
  mileage             Int?
  conditionSummary    String?

  requestedValue      Decimal?             @db.Decimal(14, 2)
  appraisedValue      Decimal?             @db.Decimal(14, 2)
  approvedValue       Decimal?             @db.Decimal(14, 2)
  appraisalDate       DateTime?

  appraiserName       String?
  notes               String?
  isActive            Boolean              @default(true)

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("dealer_trade_ins")
  @@index([empresaId])
  @@index([targetDealerUnitId])
  @@index([status])
  @@index([isActive])
  @@unique([empresaId, tradeInNumber])
}
