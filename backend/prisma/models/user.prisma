model User {
  id            String       @id @default(cuid())
  img           String?
  nombre        String
  correo        String       @unique
  telefono      String?
  password      String
  departamento  String[]
  acceso        Access       @default(ninguno)
  estado        UserStatus   @default(activo)
  eliminado     Boolean      @default(false)
  online        Boolean      @default(false)
  fcmTokens     String[]
  google        Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  auditLogs     AuditLog[]
  memberships   Membership[]

  @@index([eliminado])
  @@index([estado])
  @@index([nombre])
}

enum UserStatus {
  pendiente
  activo
  suspendido
}

enum Access {
  limitado
  completo
  ninguno
}