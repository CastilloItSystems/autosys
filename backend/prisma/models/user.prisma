model User {
  id           String    @id @default(cuid())
  img          String?
  nombre       String
  correo       String    @unique
  telefono     String?
  password     String
  rol          Role      @default(lectura)
  departamento String[]
  acceso       Access    @default(ninguno)
  empresas     Empresa[]
  estado       UserStatus @default(activo)
  eliminado    Boolean   @default(false)
  online       Boolean   @default(false)
  fcmTokens    String[]
  google       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    AuditLog[]
}

enum UserStatus {
  pendiente
  activo
  suspendido
}

enum Role {
  superAdmin
  admin
  operador
  user
  lectura
}

enum Access {
  limitado
  completo
  ninguno
}
