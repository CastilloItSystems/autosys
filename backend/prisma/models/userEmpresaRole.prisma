// backend/prisma/models/userEmpresaRole.prisma
// Tabla de unión: usuario + empresa + rol dinámico.
// Un usuario tiene UN solo rol por empresa.
// Reemplaza la relación implícita User.empresas (many-to-many) y el campo User.rol.

model UserEmpresaRole {
  id         String      @id @default(cuid())

  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  empresaId  String
  empresa    Empresa     @relation(fields: [empresaId], references: [id_empresa], onDelete: Cascade)

  roleId     String
  role       CompanyRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  // Trazabilidad de asignación
  assignedBy String?     // ID del admin que asignó el rol
  assignedAt DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Un usuario solo puede tener UN rol por empresa
  @@unique([userId, empresaId])
  @@map("user_empresa_roles")
  @@index([userId])
  @@index([empresaId])
  @@index([roleId])
}
