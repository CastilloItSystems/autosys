// backend/prisma/models/crm/interaction.prisma
// Historial de cada comunicación / punto de contacto con el cliente.
// Se registra manualmente por el asesor o automáticamente por el sistema.

enum InteractionType {
  CALL          // Llamada telefónica
  WHATSAPP      // Mensaje WhatsApp
  EMAIL         // Correo electrónico
  VISIT         // Visita presencial
  NOTE          // Nota interna
  QUOTE         // Cotización enviada
  FOLLOW_UP     // Seguimiento
  MEETING       // Reunión
}

enum InteractionChannel {
  REPUESTOS
  TALLER
  VEHICULOS
  GENERAL
}

enum InteractionDirection {
  INBOUND   // El cliente contactó a la empresa
  OUTBOUND  // La empresa contactó al cliente
}

model Interaction {
  id            String               @id @default(uuid())

  empresaId     String
  empresa       Empresa              @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  customerId    String
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // Contexto opcional
  leadId        String?
  lead          Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Clasificación
  type          InteractionType
  channel       InteractionChannel   @default(GENERAL)
  direction     InteractionDirection @default(OUTBOUND)

  // Contenido
  subject       String?
  notes         String               @db.Text

  // Resultado y próximo paso
  outcome       String?              // Ej: "Cliente interesado", "Solicitó cotización", "No contesta"
  nextAction    String?              // Ej: "Llamar en 3 días", "Enviar proforma"
  nextActionAt  DateTime?            // Fecha del próximo seguimiento

  // Quién la registró
  createdBy     String               // userId

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("crm_interactions")
  @@index([empresaId])
  @@index([customerId])
  @@index([leadId])
  @@index([type])
  @@index([channel])
  @@index([createdAt])
  @@index([nextActionAt])
}
