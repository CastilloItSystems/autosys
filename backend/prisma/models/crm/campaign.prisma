enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignChannel {
  EMAIL
  WHATSAPP
  PHONE
  SOCIAL_MEDIA
  WEB
  OTHER
}

model Campaign {
  id                   String          @id @default(cuid())
  empresaId            String
  empresa              Empresa         @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  name                 String
  description          String?         @db.Text
  status               CampaignStatus  @default(DRAFT)
  channel              CampaignChannel @default(OTHER)

  budget               Decimal?        @db.Decimal(12, 2)
  startsAt             DateTime?
  endsAt               DateTime?

  sentCount            Int             @default(0)
  responseCount        Int             @default(0)
  leadsCreatedCount    Int             @default(0)
  opportunitiesCount   Int             @default(0)
  opportunitiesWonCount Int            @default(0)

  leads                Lead[]
  opportunities        Opportunity[]
  audience             CampaignAudience[]
  results              CampaignResult[]

  createdBy            String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@map("crm_campaigns")
  @@index([empresaId])
  @@index([status])
  @@index([channel])
  @@index([startsAt])
}

model CampaignAudience {
  id                   String      @id @default(cuid())
  empresaId            String
  empresa              Empresa     @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  campaignId           String
  campaign             Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  segment              String
  filters              Json?
  audienceSize         Int         @default(0)

  createdAt            DateTime    @default(now())

  @@map("crm_campaign_audiences")
  @@index([empresaId])
  @@index([campaignId])
}

model CampaignResult {
  id                   String      @id @default(cuid())
  empresaId            String
  empresa              Empresa     @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  campaignId           String
  campaign             Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  reportedAt           DateTime    @default(now())
  sent                 Int         @default(0)
  responses            Int         @default(0)
  leadsCreated         Int         @default(0)
  opportunitiesCreated Int         @default(0)
  opportunitiesWon     Int         @default(0)
  notes                String?     @db.Text

  @@map("crm_campaign_results")
  @@index([empresaId])
  @@index([campaignId])
  @@index([reportedAt])
}
