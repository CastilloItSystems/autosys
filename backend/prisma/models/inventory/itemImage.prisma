// backend/prisma/models/inventory/itemImage.prisma

model ItemImage {
  id        String   @id @default(uuid())
  
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  url       String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  
  createdAt DateTime @default(now())

  @@map("item_images")
  @@index([itemId])
}