// backend/prisma/models/inventory/supplier.prisma

model Supplier {
  id              String          @id @default(uuid())
  code            String
  name            String
  contactName     String?
  email           String?
  phone           String?
  address         String?
  taxId           String?         // RIF en Venezuela
  isActive        Boolean         @default(true)
  
  // Multi-tenancy
  empresaId       String
  empresa         Empresa         @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relaciones
  purchaseOrders  PurchaseOrder[]
  entryNotes      EntryNote[]
  
  // Auditoría
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([empresaId, code])
  @@map("suppliers")
  @@index([isActive])
  @@index([empresaId])
}