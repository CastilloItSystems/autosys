// backend/prisma/models/inventory/supplier.prisma

enum SupplierType {
  INDIVIDUAL
  COMPANY
}

model Supplier {
  id                String          @id @default(uuid())
  code              String
  taxId             String?         // RIF/Cédula unificado
  name              String
  contactName       String?
  email             String?
  phone             String?
  mobile            String?         // celular
  website           String?         // wwwsite
  address           String?         @db.Text
  
  // Fiscal / Comercial
  type              SupplierType    @default(COMPANY)
  isSpecialTaxpayer Boolean         @default(false) // esagretesp / agente de retención
  creditDays        Int             @default(0)     // dias
  currency          String?         // moneda
  
  // CRM / Extra
  notes             String?         @db.Text        // notas / historia
  metadata          Json?           // info bancaria, campos extra, etc.

  isActive          Boolean         @default(true)
  
  // Multi-tenancy
  empresaId         String
  empresa           Empresa         @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relaciones
  purchaseOrders    PurchaseOrder[]
  entryNotes        EntryNote[]
  
  // Auditoría
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([empresaId, code])
  @@unique([empresaId, taxId])
  @@map("suppliers")
  @@index([code])
  @@index([taxId])
  @@index([isActive])
  @@index([empresaId])
}