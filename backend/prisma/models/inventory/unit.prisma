// backend/prisma/models/inventory/unit.prisma

enum UnitType {
  COUNTABLE  // Unidades contables
  WEIGHT     // Peso
  VOLUME     // Volumen
  LENGTH     // Longitud
}

model Unit {
  id           String   @id @default(uuid())
  code         String
  name         String
  abbreviation String
  type         UnitType
  isActive     Boolean  @default(true)
  
  // Multi-tenancy
  empresaId    String
  empresa      Empresa  @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relaciones
  items        Item[]
  
  // Auditoría
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([empresaId, code])
  @@unique([empresaId, abbreviation])
  @@map("units")
  @@index([code])
  @@index([type])
  @@index([empresaId])
}