// backend/prisma/models/inventory/brand.prisma

enum BrandType {
  VEHICLE       // Marca de vehículo
  PART          // Marca de producto/repuesto
  BOTH          // Ambas
}

model Brand {
  id          String    @id @default(uuid())
  code        String
  name        String
  description String?
  type        BrandType @default(PART)
  isActive    Boolean   @default(true)
  
  // Multi-tenancy
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relaciones
  items            Item[]
  models           Model[]
  customerVehicles CustomerVehicle[]
  dealerUnits      DealerUnit[]
  
  // Auditoría
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([empresaId, code])
  @@map("brands")
  @@index([code])
  @@index([name])
  @@index([type])
  @@index([isActive])
  @@index([empresaId])
}
