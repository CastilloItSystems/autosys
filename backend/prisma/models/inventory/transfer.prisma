// backend/prisma/models/inventory/transfer.prisma

enum TransferStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  IN_TRANSIT
  RECEIVED
  REJECTED
  CANCELLED
}

model Transfer {
  id               String         @id @default(uuid())
  transferNumber   String         @unique
  code             String?        // Código alternativo para búsquedas

  fromWarehouseId  String
  fromWarehouse    Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id], onDelete: Restrict)

  toWarehouseId    String
  toWarehouse      Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id], onDelete: Restrict)

  status           TransferStatus @default(DRAFT)
  quantity         Int            @default(0)

  notes            String?        @db.Text

  // Approval fields
  approvedBy       String?
  approvedAt       DateTime?
  rejectedBy       String?
  rejectedAt       DateTime?
  rejectionReason  String?        @db.Text

  // Transit fields
  sentAt           DateTime?
  receivedAt       DateTime?

  createdBy        String

  // Documentos generados al aprobar
  exitNoteId       String?        @unique
  exitNote         ExitNote?      @relation(fields: [exitNoteId], references: [id], onDelete: SetNull)

  entryNoteId      String?        @unique
  entryNote        EntryNote?     @relation(fields: [entryNoteId], references: [id], onDelete: SetNull)

  items            TransferItem[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("transfers")
  @@index([transferNumber])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@index([fromWarehouseId, status])
  @@index([toWarehouseId, status])
}

model TransferItem {
  id           String    @id @default(uuid())

  transferId   String
  transfer     Transfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)

  itemId       String
  item         Item      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  quantity     Int
  unitCost     Decimal?  @db.Decimal(12, 2)

  notes        String?   @db.Text

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("transfer_items")
  @@index([transferId])
  @@index([itemId])
}
