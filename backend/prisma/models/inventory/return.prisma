// backend/prisma/models/inventory/return.prisma

enum ReturnStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PROCESSED
  REJECTED
  CANCELLED
}

enum ReturnType {
  SUPPLIER_RETURN
  WORKSHOP_RETURN
  CUSTOMER_RETURN
}

model ReturnOrder {
  id            String       @id @default(uuid())
  returnNumber  String       @unique
  type          ReturnType
  status        ReturnStatus @default(DRAFT)
  
  warehouseId   String
  warehouse     Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  reason        String       @db.VarChar(500)
  notes         String?      @db.Text
  
  approvedBy    String?
  approvedAt    DateTime?
  processedBy   String?
  processedAt   DateTime?
  
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items         ReturnOrderItem[]

  @@map("returns")
  @@index([returnNumber])
  @@index([type])
  @@index([status])
  @@index([warehouseId])
  @@index([createdAt])
}

model ReturnOrderItem {
  id            String       @id @default(uuid())
  
  returnOrderId String
  returnOrder   ReturnOrder  @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  
  itemId        String
  item          Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  quantity      Int
  unitPrice     Decimal?     @db.Decimal(12, 2)
  notes         String?      @db.Text
  
  createdAt     DateTime     @default(now())

  @@map("return_items")
  @@index([returnOrderId])
  @@index([itemId])
  @@unique([returnOrderId, itemId])
}
