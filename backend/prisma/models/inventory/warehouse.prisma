// backend/prisma/models/inventory/warehouse.prisma

enum WarehouseType {
  PRINCIPAL  // Almacén principal
  SUCURSAL   // Sucursal/Tienda
  TRANSITO   // Almacén de tránsito
}

model Warehouse {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  type        WarehouseType @default(PRINCIPAL)
  address     String?
  isActive    Boolean       @default(true)
  
  // Multi-tenancy
  empresaId   String
  empresa     Empresa       @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relaciones
  stocks          Stock[]
  movementsFrom   Movement[]    @relation("WarehouseFrom")
  movementsTo     Movement[]    @relation("WarehouseTo")
  orders          Order[]
  preInvoices     PreInvoice[]
  exitNotes       ExitNote[]
  purchaseOrders  PurchaseOrder[]
  adjustments     Adjustment[]
  cycleCounts     CycleCount[]
  reconciliations Reconciliation[]
  loans           Loan[]
  returnOrders    ReturnOrder[]
  serialNumbers   SerialNumber[]
  transfersFrom   Transfer[]     @relation("TransferFrom")
  transfersTo     Transfer[]     @relation("TransferTo")
  
  // Auditoría
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("warehouses")
  @@index([code])
  @@index([type])
  @@index([isActive])
  @@index([empresaId])
}