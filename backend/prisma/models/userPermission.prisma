// backend/prisma/models/userPermission.prisma
// Permisos individuales por usuario (overrides sobre el rol base)

enum PermissionAction {
  GRANT   // Agrega el permiso aunque el rol no lo tenga
  REVOKE  // Quita el permiso aunque el rol lo tenga
}

model UserPermission {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String           // Ej: "inventory:view", "reports:export"
  action     PermissionAction @default(GRANT)
  reason     String?          // Nota del admin sobre por qué se asignó
  grantedBy  String?          // ID del admin que lo asignó
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([userId, permission])
  @@map("user_permissions")
  @@index([userId])
  @@index([permission])
}
