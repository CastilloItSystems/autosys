model Empresa {
  id_empresa      String       @id @default(cuid())
  nombre          String
  direccion       String?
  telefonos       String?
  fax             String?
  numerorif       String?
  numeronit       String?
  website         String?
  email           String?
  contacto        String?
  predeter        Boolean      @default(false)
  soporte1        String?
  soporte2        String?
  soporte3        String?
  data_usaweb     Boolean      @default(false)
  data_servidor   String?
  data_usuario    String?
  data_password   String?
  data_port       String?
  licencia        String?
  logo_url        String?
  historizada     Boolean      @default(false)
  masinfo         String?
  usa_prefijo     Boolean      @default(false)
  name_prefijo    String?
  dprefijobd      String?
  dprefijosrv     String?
  dprefijousr     String?
  eliminado       Boolean      @default(false)

  memberships     Membership[]
  companyRoles    CompanyRole[]

  warehouses      Warehouse[]
  items           Item[]
  suppliers       Supplier[]
  brands          Brand[]
  categories      Category[]
  units           Unit[]
  models          Model[]

  // Sales
  customers       Customer[]
  orders          Order[]
  preInvoices     PreInvoice[]
  invoices        Invoice[]
  payments        Payment[]

  // CRM
  customerContacts CustomerContact[]
  customerVehicles CustomerVehicle[]
  leads            Lead[]
  interactions     Interaction[]
  activities       Activity[]
  quotes           Quote[]
  cases            Case[]

  // Workshop (Taller)
  serviceOrders       ServiceOrder[]
  serviceAppointments ServiceAppointment[]
  vehicleReceptions   VehicleReception[]
  serviceTypes        ServiceType[]
  workshopBays        WorkshopBay[]
  workshopOperations  WorkshopOperation[]
  workshopWarranties  WorkshopWarranty[]
  
  // Nuevas entidades Workshop ERP Opción 3
  checklistTemplates          ChecklistTemplate[]
  checklistItems              ChecklistItem[]
  checklistResponses          ChecklistResponse[]
  serviceDiagnoses            ServiceDiagnosis[]
  diagnosisFindings           DiagnosisFinding[]
  diagnosisSuggestedOps       DiagnosisSuggestedOperation[]
  diagnosisSuggestedParts     DiagnosisSuggestedPart[]
  diagnosisEvidences          DiagnosisEvidence[]
  serviceOrderStatusHistories ServiceOrderStatusHistory[]
  appointmentStatusHistories  AppointmentStatusHistory[]
  vehicleDeliveries           VehicleDelivery[]

  // Nuevas entidades Workshop Adicionales
  ingressMotives              IngressMotive[]
  technicianSpecialties       TechnicianSpecialty[]
  laborTimePauses             LaborTimePause[]
  serviceOrderMaterials       ServiceOrderMaterial[]
  serviceOrderAdditionals     ServiceOrderAdditional[]
  serviceOrderObservations    ServiceOrderObservation[]

  // Workshop Prioridad 2
  receptionDamages            ReceptionDamage[]
  receptionPhotos             ReceptionPhoto[]
  workshopAttachments         WorkshopAttachment[]
  materialMovements           ServiceOrderMaterialMovement[]

  // Workshop Prioridad 3
  workshopReworks             WorkshopRework[]
  workshopAuditLogs           WorkshopAuditLog[]
  workshopShifts              WorkshopShift[]
  workshopQuotations          WorkshopQuotation[]
  workshopTOTs                WorkshopTOT[]
  workshopGarita              WorkshopGarita[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}
