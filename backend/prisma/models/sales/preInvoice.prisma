// backend/prisma/models/sales/preInvoice.prisma

enum PreInvoiceStatus {
  PENDING_PREPARATION  // Pendiente de preparación
  IN_PREPARATION       // En preparación
  READY_FOR_PAYMENT    // Listo para pago
  PAID                 // Pagado
  CANCELLED            // Cancelado
}

model PreInvoice {
  id                  String            @id @default(uuid())
  preInvoiceNumber    String            @unique
  status              PreInvoiceStatus  @default(PENDING_PREPARATION)
  
  empresaId           String
  empresa             Empresa           @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relación 1 a 1 con Order
  orderId             String            @unique
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  
  customerId          String
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  warehouseId         String
  warehouse           Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  // Relaciones
  items               PreInvoiceItem[]
  
  // Totales
  subtotal            Decimal           @default(0) @db.Decimal(12, 2)
  discount            Decimal           @default(0) @db.Decimal(12, 2)
  tax                 Decimal           @default(0) @db.Decimal(12, 2)
  total               Decimal           @default(0) @db.Decimal(12, 2)
  
  notes               String?           @db.Text
  
  // Control de flujo
  preparedAt          DateTime?
  paidAt              DateTime?
  
  preparedBy          String?
  
  // Relaciones 1 a 1
  exitNote            ExitNote?
  invoice             Invoice?
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("pre_invoices")
  @@index([preInvoiceNumber])
  @@index([customerId])
  @@index([status])
  @@index([empresaId])
}