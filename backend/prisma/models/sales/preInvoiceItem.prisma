// backend/prisma/models/sales/preInvoiceItem.prisma

model PreInvoiceItem {
  id              String        @id @default(uuid())

  preInvoiceId    String
  preInvoice      PreInvoice    @relation(fields: [preInvoiceId], references: [id], onDelete: Cascade)

  itemId          String
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)

  // ── Snapshot ──
  itemName        String?       @db.VarChar(255)

  quantity        Int
  unitPrice       Decimal       @db.Decimal(12, 2)

  // ── Descuento por línea ──
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)

  // ── Impuesto por línea ──
  taxType         TaxType       @default(IVA)
  taxRate         Decimal       @default(16) @db.Decimal(5, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)

  // ── Subtotal y total línea ──
  subtotal        Decimal       @db.Decimal(12, 2)
  totalLine       Decimal       @default(0) @db.Decimal(12, 2)

  // ── Legacy ──
  discount        Decimal       @default(0) @db.Decimal(12, 2)

  // Trazabilidad
  batchId         String?
  batch           Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)

  serialNumberId  String?
  serialNumber    SerialNumber? @relation(fields: [serialNumberId], references: [id], onDelete: SetNull)

  notes           String?       @db.Text

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("pre_invoice_items")
  @@index([preInvoiceId])
  @@index([itemId])
}
