// backend/prisma/models/sales/invoice.prisma

enum InvoiceStatus {
  ACTIVE     // Activa
  CANCELLED  // Anulada
  CREDITED   // Con nota de crédito
}

model Invoice {
  id                 String        @id @default(uuid())
  invoiceNumber      String        @unique
  fiscalNumber       String?       @unique // Número de control fiscal
  status             InvoiceStatus @default(ACTIVE)

  empresaId          String
  empresa            Empresa       @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)

  // Relación con PreInvoice
  preInvoiceId       String        @unique
  preInvoice         PreInvoice    @relation(fields: [preInvoiceId], references: [id], onDelete: Restrict)

  // Relación con Payment (el pago que generó esta factura)
  paymentId          String        @unique
  payment            Payment       @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  customerId         String
  customer           Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // Relaciones
  items              InvoiceItem[]

  // Workshop: OT facturada con esta invoice
  serviceOrder       ServiceOrder?

  // ── Moneda ──
  currency           OrderCurrency @default(USD)
  exchangeRate       Decimal?      @db.Decimal(14, 4)

  // ── Descuento general ──
  discountAmount     Decimal       @default(0) @db.Decimal(12, 2)

  // ── Totales fiscales ──
  subtotalBruto      Decimal       @default(0) @db.Decimal(12, 2)
  baseImponible      Decimal       @default(0) @db.Decimal(12, 2)
  baseExenta         Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount          Decimal       @default(0) @db.Decimal(12, 2)
  taxRate            Decimal       @default(16) @db.Decimal(5, 2)

  // ── IGTF ──
  igtfApplies        Boolean       @default(false)
  igtfRate           Decimal       @default(3) @db.Decimal(5, 2)
  igtfAmount         Decimal       @default(0) @db.Decimal(12, 2)

  // ── Total ──
  total              Decimal       @default(0) @db.Decimal(12, 2)

  // ── Legacy ──
  subtotal           Decimal       @default(0) @db.Decimal(12, 2)
  discount           Decimal       @default(0) @db.Decimal(12, 2)
  tax                Decimal       @default(0) @db.Decimal(12, 2)

  notes              String?       @db.Text

  // Fiscal
  invoiceDate        DateTime      @default(now())

  // Auditoría
  issuedBy           String?

  // Anulación
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?       @db.Text

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("invoices")
  @@index([invoiceNumber])
  @@index([fiscalNumber])
  @@index([customerId])
  @@index([preInvoiceId])
  @@index([status])
  @@index([invoiceDate])
  @@index([empresaId])
}
