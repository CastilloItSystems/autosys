// backend/prisma/models/sales/customer.prisma

enum CustomerType {
  INDIVIDUAL  // Persona natural
  COMPANY     // Empresa
}

model Customer {
  id                String       @id @default(uuid())
  code              String
  taxId             String?      // RIF/Cédula unificado
  name              String
  email             String?
  phone             String?
  mobile            String?      // telefono_movil
  website           String?      // wwwcli
  contactPerson     String?      // perscont
  
  // Direcciones
  address           String?      @db.Text
  shippingAddress   String?      @db.Text // direcenvio
  billingAddress    String?      @db.Text // direccobro
  
  // Fiscal / Configuración
  type              CustomerType @default(INDIVIDUAL)
  isSpecialTaxpayer Boolean      @default(false) // contribespecial
  priceList         Int          @default(1)     // precio
  
  // Condiciones de Crédito y Venta
  creditLimit       Float        @default(0)     // limite
  creditDays        Int          @default(0)     // dias
  defaultDiscount   Float        @default(0)     // descuento
  sellerId          String?                      // vendedor
  
  // CRM / Extra
  notes             String?      @db.Text        // nota / historia
  metadata          Json?                        // Para reemplazar campo1..5, hashtag, etc.

  isActive          Boolean      @default(true)
  
  // Multi-tenancy
  empresaId         String
  empresa           Empresa      @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relaciones
  orders            Order[]
  preInvoices       PreInvoice[]
  payments          Payment[]
  invoices          Invoice[]
  
  // Auditoría
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([empresaId, code])
  @@unique([empresaId, taxId])
  @@map("customers")
  @@index([code])
  @@index([taxId])
  @@index([isActive])
  @@index([empresaId])
}