// backend/prisma/models/sales/customer.prisma

enum CustomerType {
  INDIVIDUAL  // Persona natural
  COMPANY     // Empresa
}

model Customer {
  id          String       @id @default(uuid())
  code        String
  taxId       String?      // RIF/Cédula
  name        String
  email       String?
  phone       String?
  address     String?      @db.Text
  type        CustomerType @default(INDIVIDUAL)
  
  isActive    Boolean      @default(true)
  
  // Multi-tenancy
  empresaId   String
  empresa     Empresa      @relation(fields: [empresaId], references: [id_empresa], onDelete: Restrict)
  
  // Relaciones
  orders      Order[]
  preInvoices PreInvoice[]
  payments    Payment[]
  invoices    Invoice[]
  
  // Auditoría
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([empresaId, code])
  @@unique([empresaId, taxId])
  @@map("customers")
  @@index([code])
  @@index([taxId])
  @@index([isActive])
  @@index([empresaId])
}